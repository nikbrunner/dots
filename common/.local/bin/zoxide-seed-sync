#!/usr/bin/env bash
# Regenerate zoxide/seed.txt from current ~/repos/<owner>/<repo> paths and
# seed the local zoxide database. Runs hourly via LaunchAgent (macOS) or
# systemd timer (Arch), and on fresh-machine bootstrap.

set -euo pipefail

SEED_FILE="$HOME/.config/zoxide/seed.txt"
REPOS_DIR="$HOME/repos"

{
	echo "# Zoxide seed paths — auto-generated by zoxide-seed-sync, do not edit by hand."
	echo "# Regenerated hourly from \$HOME/repos/<owner>/<repo>."
	echo
	echo "# Config"
	echo "~/.config"
	echo "~/.config/nvim"
	echo
	echo "# Repos"
	if [[ -d "$REPOS_DIR" ]]; then
		find "$REPOS_DIR" -mindepth 2 -maxdepth 2 -type d | sort | sed "s|^$HOME|~|"
	fi
} >"$SEED_FILE"

# Only seed paths zoxide doesn't already know about. zoxide's frecency score
# applies a x4 "visited in the last hour" multiplier on every `add` call, so
# re-adding on this hourly cron would make every seeded path look constantly
# visited and drown out real usage. Once a path is in the db, real `cd`
# activity (via the shell hook) is what should move its score from then on.
known="$(zoxide query -l)"

while IFS= read -r line; do
	[[ -z "$line" || "$line" == \#* ]] && continue
	path="${line/#\~/$HOME}"
	for expanded in $path; do
		[[ -d "$expanded" ]] || continue
		grep -qxF "$expanded" <<<"$known" || zoxide add -s 1 "$expanded"
	done
done <"$SEED_FILE"
