#!/usr/bin/env bash
set -e

# Stop hook: Block Claude from finishing if there are NEW uncommitted git changes
# (beyond what existed at session start) AND Claude actually modified files.
#
# Flow:
# 1. Check transcript for file-modifying tool usage (Edit, Write, MultiEdit, NotebookEdit)
# 2. No file modifications → allow stop (pure Q&A, no blocking)
# 3. File modifications + new uncommitted changes → block for verification
# 4. Claude runs lint/test/format → stops again → stop_hook_active = true → allow

input=$(cat)

stop_hook_active=$(echo "$input" | jq -r '.stop_hook_active // false')
cwd=$(echo "$input" | jq -r '.cwd // ""')
transcript_path=$(echo "$input" | jq -r '.transcript_path // ""')

# If we already blocked once, let Claude through
if [ "$stop_hook_active" = "true" ]; then
	exit 0
fi

# Skip verification for repos that have frequent auto-changing files
skip_repos=(
	"nikbrunner/dots"
)

for repo in "${skip_repos[@]}"; do
	if [[ "$cwd" == *"$repo"* ]]; then
		exit 0
	fi
done

# Check if Claude actually modified files by scanning the transcript.
# Only check for dedicated file-writing tools — Bash is too broad (git log, ls, etc.)
if [ -n "$transcript_path" ] && [ -f "$transcript_path" ]; then
	has_file_modifications=$(grep -cE '"(Edit|Write|MultiEdit|NotebookEdit)"' "$transcript_path" 2>/dev/null || true)

	if [ "${has_file_modifications:-0}" = "0" ]; then
		exit 0
	fi
fi

# Check if we're in a git repo
if [ -z "$cwd" ]; then
	exit 0
fi

if ! { [ -d "$cwd/.git" ] || git -C "$cwd" rev-parse --git-dir >/dev/null 2>&1; }; then
	exit 0
fi

current_changes=$(git -C "$cwd" status --porcelain 2>/dev/null || true)

# No changes at all — allow stop
if [ -z "$current_changes" ]; then
	exit 0
fi

# Use a snapshot file to track pre-existing changes from session start.
# The snapshot is keyed by repo path (hashed) so multiple repos don't collide.
# Also track the commit hash so we refresh the baseline after commits.
snapshot_dir="${TMPDIR:-/tmp}/claude-stop-hook"
mkdir -p "$snapshot_dir"
repo_hash=$(echo "$cwd" | md5 -q 2>/dev/null || echo "$cwd" | md5sum | cut -d' ' -f1)
snapshot_file="$snapshot_dir/$repo_hash"
head_file="$snapshot_dir/${repo_hash}.head"

current_head=$(git -C "$cwd" rev-parse HEAD 2>/dev/null || echo "none")

# Refresh baseline if HEAD moved (Claude committed something mid-session)
if [ -f "$head_file" ]; then
	saved_head=$(cat "$head_file")
	if [ "$saved_head" != "$current_head" ]; then
		# HEAD changed — Claude committed. Refresh baseline to current state.
		echo "$current_changes" >"$snapshot_file"
		echo "$current_head" >"$head_file"
	fi
fi

# First run: save snapshot of pre-existing changes
if [ ! -f "$snapshot_file" ]; then
	echo "$current_changes" >"$snapshot_file"
	echo "$current_head" >"$head_file"
fi

baseline=$(cat "$snapshot_file")

# Only block if there are NEW dirty files not in the baseline.
# Lines starting with ">" in diff output = new entries in current_changes.
# Ignore lines that were removed (Claude committed them) — those are fine.
new_dirty=$(diff <(echo "$baseline") <(echo "$current_changes") 2>/dev/null | grep '^> ' || true)

if [ -z "$new_dirty" ]; then
	exit 0
fi

cat <<'EOF'
{
    "decision": "block",
    "reason": "You have uncommitted changes from this session. Before finishing: (1) Run lint/format/test commands appropriate for this project. (2) Do NOT discard or revert files. (3) Briefly report results to the user."
}
EOF
exit 0
