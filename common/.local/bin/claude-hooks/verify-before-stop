#!/usr/bin/env bash
set -e

# Stop hook: Block Claude from finishing if there are NEW uncommitted git changes
# (beyond what existed at session start) and verification hasn't been done yet.
#
# Flow:
# 1. First invocation: snapshot current git status to a temp file
# 2. Claude finishes → this hook fires
# 3. If there are NEW changes (not in snapshot) AND stop_hook_active is false → block
# 4. Claude runs appropriate lint/test/format commands for the project
# 5. Claude stops again → stop_hook_active is true → allow through

input=$(cat)

stop_hook_active=$(echo "$input" | jq -r '.stop_hook_active // false')
cwd=$(echo "$input" | jq -r '.cwd // ""')

# If we already blocked once, let Claude through
if [ "$stop_hook_active" = "true" ]; then
    exit 0
fi

# Skip verification for repos that have frequent auto-changing files
skip_repos=(
    "nikbrunner/dots"
)

for repo in "${skip_repos[@]}"; do
    if [[ "$cwd" == *"$repo"* ]]; then
        exit 0
    fi
done

# Check if we're in a git repo
if [ -z "$cwd" ]; then
    exit 0
fi

if ! { [ -d "$cwd/.git" ] || git -C "$cwd" rev-parse --git-dir > /dev/null 2>&1; }; then
    exit 0
fi

current_changes=$(git -C "$cwd" status --porcelain 2>/dev/null || true)

# No changes at all — allow stop
if [ -z "$current_changes" ]; then
    exit 0
fi

# Use a snapshot file to track pre-existing changes from session start.
# The snapshot is keyed by repo path (hashed) so multiple repos don't collide.
snapshot_dir="${TMPDIR:-/tmp}/claude-stop-hook"
mkdir -p "$snapshot_dir"
repo_hash=$(echo "$cwd" | md5 -q 2>/dev/null || echo "$cwd" | md5sum | cut -d' ' -f1)
snapshot_file="$snapshot_dir/$repo_hash"

# First run: save snapshot of pre-existing changes and compare
if [ ! -f "$snapshot_file" ]; then
    echo "$current_changes" > "$snapshot_file"
fi

baseline=$(cat "$snapshot_file")

# Compare: only block if there are changes beyond the baseline
new_changes=$(diff <(echo "$baseline") <(echo "$current_changes") 2>/dev/null || true)

if [ -z "$new_changes" ]; then
    # No new changes beyond what existed at session start — allow stop
    exit 0
fi

cat <<'EOF'
{
    "decision": "block",
    "reason": "You have made changes during this session that are not yet committed. Before finishing, please: (1) Run the appropriate lint, format, and test commands for this project — check the project structure (package.json, deno.json, Makefile, Cargo.toml, etc.) to determine the right commands. (2) Do NOT discard, checkout, or revert any files. (3) Report your verification results to the user."
}
EOF
exit 0
