#!/usr/bin/env bash
# New dots command for symlink-based dotfiles management

set -e

# Get the dots directory
DOTS_DIR="${DOTS_DIR:-$HOME/repos/nikbrunner/dots}"

# Capture the original working directory before changing to dots dir
ORIGINAL_PWD="$(pwd)"

# Source shared dots library for pull/push commands
# shellcheck disable=SC1091
source "$DOTS_DIR/scripts/dots-lib.sh"

# Change to dots directory for git operations
cd "$DOTS_DIR"

# Check for gum and provide helpful message if missing
check_gum() {
	if ! command -v gum >/dev/null 2>&1; then
		echo "⚠ gum not found - install for enhanced UI:"
		echo "  macOS: brew install gum"
		echo "  Linux: See https://github.com/charmbracelet/gum#installation"
		echo ""
		return 1
	fi
	return 0
}

# Enhanced output functions using gum when available
log_section() {
	if command -v gum >/dev/null 2>&1; then
		gum style --foreground=4 --bold "$1"
	else
		echo "$1"
	fi
}

log_success() {
	if command -v gum >/dev/null 2>&1; then
		gum style --foreground=2 "✓ $1"
	else
		echo "✓ $1"
	fi
}

log_warning() {
	if command -v gum >/dev/null 2>&1; then
		gum style --foreground=3 "⚠ $1"
	else
		echo "⚠ $1"
	fi
}

log_error() {
	if command -v gum >/dev/null 2>&1; then
		gum style --foreground=1 "✗ $1"
	else
		echo "✗ $1"
	fi
}

log_info() {
	if command -v gum >/dev/null 2>&1; then
		gum style --foreground=6 "→ $1"
	else
		echo "→ $1"
	fi
}

# ── Pull command ───────────────────────────────────────────────
# Full machine sync: pull dots, deps, link, pull all repos, rebuild tools
cmd_pull() {
	local hard_reset=false
	local rebuild_all=false

	while [[ $# -gt 0 ]]; do
		case "$1" in
		--hard)
			hard_reset=true
			shift
			;;
		--rebuild-all)
			rebuild_all=true
			shift
			;;
		*) shift ;;
		esac
	done

	# ── Phase 1: Sync dots repo ──
	log_section "Phase 1: Sync dots repository"

	local pull_output pull_failed=false
	if ! pull_output=$(git pull origin main 2>&1); then
		if ! pull_output=$(git pull origin master 2>&1); then
			pull_failed=true
		fi
	fi

	if [[ "$pull_failed" == true ]]; then
		log_error "Failed to pull dots repo"
		echo "$pull_output" | sed 's/^/  /'
		return 1
	fi
	log_success "Dots repo pulled"

	# ── Phase 2: Check dependencies ──
	echo ""
	log_section "Phase 2: Check dependencies"
	if "$DOTS_DIR/scripts/deps/install.sh" check 2>/dev/null; then
		log_success "All dependencies present"
	else
		log_warning "Some dependencies may be missing"
		if command -v gum >/dev/null 2>&1; then
			if gum confirm "Install missing dependencies?"; then
				"$DOTS_DIR/scripts/deps/install.sh" install || true
			fi
		else
			log_info "Run 'dots deps install' to install missing dependencies"
		fi
	fi

	# ── Phase 3: Update symlinks ──
	echo ""
	log_section "Phase 3: Update symlinks"
	cmd_link

	# ── Phase 4: Pull all repos ──
	echo ""
	log_section "Phase 4: Pull all repositories"
	load_config

	local repos
	repos=$(list_repos)

	if [[ -z "$repos" ]]; then
		log_warning "No repositories found"
	else
		local repo_list=()
		while IFS= read -r repo; do
			[[ -z "$repo" ]] && continue
			local repo_path="$REPOS_BASE_PATH/$repo"
			if [[ -d "$repo_path/.git" ]]; then
				# Skip dots repo itself (already handled in Phase 1)
				if is_dots_repo "$repo_path"; then
					continue
				fi
				repo_list+=("$repo")
			fi
		done <<<"$repos"

		local total=${#repo_list[@]}
		log_info "Found $total git repositories"
		echo ""

		local ok_count=0
		local up_to_date_count=0
		local reset_count=0
		local skip_count=0
		local current=1
		local skipped_repos=()
		local updated_repos=()

		for repo in "${repo_list[@]}"; do
			local repo_path="$REPOS_BASE_PATH/$repo"

			# Fetch first to get accurate state
			git -C "$repo_path" fetch --quiet 2>/dev/null || true

			local state_info
			state_info=$(get_repo_state "$repo_path")
			local state="${state_info%%:*}"
			local counts="${state_info#*:}"
			local ahead="${counts%%:*}"
			local behind="${counts#*:}"

			echo -n "[$current/$total] $repo "

			case "$state" in
			clean)
				echo "✓ up to date"
				((up_to_date_count++)) || true
				;;
			behind)
				echo -n "(↓$behind) pulling... "
				if git -C "$repo_path" pull --quiet 2>/dev/null; then
					print_success "updated"
					updated_repos+=("$repo")
					((ok_count++)) || true
				else
					print_error "pull failed"
					skipped_repos+=("$repo")
					((skip_count++)) || true
				fi
				;;
			ahead)
				echo -e "${YELLOW}↑$ahead ahead${NC} (nothing to pull)"
				((up_to_date_count++)) || true
				;;
			diverged)
				echo -e "${YELLOW}diverged${NC} (↑$ahead ↓$behind)"
				if [[ "$hard_reset" == true ]]; then
					echo -n "  → resetting to remote... "
					if fullreset_repo "$repo_path"; then
						print_success "reset"
						updated_repos+=("$repo")
						((reset_count++)) || true
					else
						print_error "reset failed"
						skipped_repos+=("$repo")
						((skip_count++)) || true
					fi
				else
					local do_reset=false
					if has_gum; then
						gum confirm "  Reset to remote? (discards $ahead local commits)" && do_reset=true
					else
						echo -n "  Reset to remote? (discards $ahead local commits) (y/N) "
						read -r confirm_reset
						[[ "$confirm_reset" == "y" || "$confirm_reset" == "Y" ]] && do_reset=true
					fi

					if [[ "$do_reset" == true ]]; then
						echo -n "  → resetting... "
						if fullreset_repo "$repo_path"; then
							print_success "reset"
							updated_repos+=("$repo")
							((reset_count++)) || true
						else
							print_error "reset failed"
							skipped_repos+=("$repo")
							((skip_count++)) || true
						fi
					else
						echo "  → skipped"
						skipped_repos+=("$repo")
						((skip_count++)) || true
					fi
				fi
				;;
			dirty | dirty+behind)
				echo -e "${YELLOW}dirty${NC} (uncommitted changes)"
				if [[ "$hard_reset" == true ]]; then
					echo -n "  → resetting to remote... "
					if fullreset_repo "$repo_path"; then
						print_success "reset"
						updated_repos+=("$repo")
						((reset_count++)) || true
					else
						print_error "reset failed"
						skipped_repos+=("$repo")
						((skip_count++)) || true
					fi
				else
					local do_reset=false
					if has_gum; then
						gum confirm "  Reset to remote? (discards uncommitted changes)" --default=false && do_reset=true
					else
						echo -n "  Reset to remote? (discards uncommitted changes) (y/N) "
						read -r confirm_reset
						[[ "$confirm_reset" == "y" || "$confirm_reset" == "Y" ]] && do_reset=true
					fi

					if [[ "$do_reset" == true ]]; then
						echo -n "  → resetting... "
						if fullreset_repo "$repo_path"; then
							print_success "reset"
							updated_repos+=("$repo")
							((reset_count++)) || true
						else
							print_error "reset failed"
							skipped_repos+=("$repo")
							((skip_count++)) || true
						fi
					else
						echo "  → skipped"
						skipped_repos+=("$repo")
						((skip_count++)) || true
					fi
				fi
				;;
			no-upstream)
				print_warning "no upstream"
				((skip_count++)) || true
				;;
			esac
			((current++)) || true
		done

		# Summary
		echo ""
		echo "────────────────────────────────────────────────"
		log_info "Summary: $total repositories"
		[[ $ok_count -gt 0 ]] && log_success "Pulled: $ok_count"
		[[ $reset_count -gt 0 ]] && log_success "Reset: $reset_count"
		[[ $up_to_date_count -gt 0 ]] && echo "  Already up to date: $up_to_date_count"
		[[ $skip_count -gt 0 ]] && log_warning "Skipped: $skip_count"

		if [[ ${#skipped_repos[@]} -gt 0 ]]; then
			echo ""
			log_warning "Skipped repos:"
			for repo in "${skipped_repos[@]}"; do
				echo "  * $repo"
			done
		fi
	fi

	# ── Phase 5: Rebuild tools ──
	echo ""
	log_section "Phase 5: Rebuild tools"

	local entries=()
	while IFS= read -r line; do
		[[ -n "$line" ]] && entries+=("$line")
	done < <(get_ensure_cloned 2>/dev/null || true)

	if [[ ${#entries[@]} -eq 0 ]]; then
		log_info "No ensure_cloned config found, skipping rebuilds"
	else
		local rebuilt=0
		for entry in "${entries[@]}"; do
			local post_clone
			post_clone=$(get_entry_post_clone "$entry")
			[[ -z "$post_clone" ]] && continue

			local url
			url=$(get_entry_url "$entry")
			# Skip wildcard patterns
			[[ "$url" == *"/*" ]] && continue

			local repo_rel
			repo_rel=$(parse_git_url "$url" 2>/dev/null) || continue
			local repo_path="$REPOS_BASE_PATH/$repo_rel"

			# Only rebuild if updated (or --rebuild-all)
			if [[ "$rebuild_all" == true ]]; then
				: # always rebuild
			else
				local was_updated=false
				for updated in "${updated_repos[@]:-}"; do
					if [[ "$updated" == "$repo_rel" ]]; then
						was_updated=true
						break
					fi
				done
				[[ "$was_updated" == false ]] && continue
			fi

			if [[ -d "$repo_path" ]]; then
				log_info "Rebuilding $(basename "$repo_path"): $post_clone"
				if (cd "$repo_path" && eval "$post_clone"); then
					log_success "Rebuilt $(basename "$repo_path")"
					((rebuilt++)) || true
				else
					log_error "Rebuild failed for $(basename "$repo_path")"
				fi
			fi
		done

		if [[ $rebuilt -eq 0 ]]; then
			log_info "No tools needed rebuilding"
		fi
	fi

	echo ""
	log_success "Arrive complete!"
}

# ── Push command ───────────────────────────────────────────────
# End of day: dots chores, commit/push dots, handle dirty repos, push all
cmd_push() {
	load_config

	# ── Phase 1: Dots chores ──
	log_section "Phase 1: Dots chores"
	dots_commit_theme "$DOTS_DIR" || true
	dots_commit_sessions "$DOTS_DIR" || true
	dots_commit_radar "$DOTS_DIR" || true

	# ── Phase 2: Commit/push dots ──
	echo ""
	log_section "Phase 2: Dots commit & push"

	local dots_dirty
	dots_dirty=$(git status --porcelain 2>/dev/null)

	if [[ -n "$dots_dirty" ]]; then
		log_warning "Dots repo has uncommitted changes:"
		git status --short
		echo ""

		local actions=(
			"Review in LazyGit"
			"Stage all and commit with AI"
			"Backup with timestamp"
			"─────────"
			"Skip"
		)

		local selected_action
		if has_gum; then
			selected_action=$(printf '%s\n' "${actions[@]}" | gum choose --header "What would you like to do with dots?")
		else
			echo "Options:"
			local i=1
			for action in "${actions[@]}"; do
				if [[ "$action" == "─────────" ]]; then
					echo "  $action"
				else
					echo "  [$i] $action"
					((i++)) || true
				fi
			done
			echo -n "Choice: "
			read -r choice
			local j=0
			for action in "${actions[@]}"; do
				if [[ "$action" != "─────────" ]]; then
					((j++)) || true
					if [[ "$j" == "$choice" ]]; then
						selected_action="$action"
						break
					fi
				fi
			done
			[[ -z "${selected_action:-}" ]] && selected_action="Skip"
		fi

		case "$selected_action" in
		"Review in LazyGit")
			lazygit
			;;
		"Stage all and commit with AI")
			if command -v repo &>/dev/null; then
				git add -A && repo commit -s -y
			else
				log_error "'repo' command not found"
			fi
			;;
		"Backup with timestamp")
			local timestamp
			timestamp=$(date "+%Y-%m-%d %H:%M")
			git add -A && git commit -m "backup: $timestamp"
			log_success "Backup commit created"
			;;
		"Skip")
			log_info "Skipping dots commit"
			;;
		esac
	else
		log_success "Dots repo is clean"
	fi

	# Push dots if unpushed commits
	if [[ -n $(git log @{u}.. 2>/dev/null) ]]; then
		do_push false
	fi

	# ── Phase 3: Handle dirty non-dots repos ──
	echo ""
	log_section "Phase 3: Handle dirty repos"

	local repos
	repos=$(list_repos)

	local dirty_repos=()
	while IFS= read -r repo; do
		[[ -z "$repo" ]] && continue
		local repo_path="$REPOS_BASE_PATH/$repo"

		[[ ! -d "$repo_path/.git" ]] && continue
		# Skip dots repo (already handled)
		is_dots_repo "$repo_path" && continue

		local status_output
		status_output=$(cd "$repo_path" && git status --porcelain 2>/dev/null)
		if [[ -n "$status_output" ]]; then
			dirty_repos+=("$repo")
		fi
	done <<<"$repos"

	if [[ ${#dirty_repos[@]} -eq 0 ]]; then
		log_success "All repos are clean"
	else
		log_info "Found ${#dirty_repos[@]} repos with uncommitted changes"
		echo ""

		local current=1
		local total=${#dirty_repos[@]}

		for repo in "${dirty_repos[@]}"; do
			local repo_path="$REPOS_BASE_PATH/$repo"

			echo ""
			echo "[$current/$total]"
			show_repo_status "$repo"
			echo ""

			local actions=(
				"Review in LazyGit"
				"Stage all and commit with AI"
				"Backup with timestamp"
				"Cleanup with Claude"
				"─────────"
				"Discard changes"
				"Push without committing"
				"Skip this repo"
				"Stop walkthrough"
			)

			local selected_action
			if has_gum; then
				selected_action=$(printf '%s\n' "${actions[@]}" | gum choose --header "What would you like to do?")
			else
				echo "Options:"
				local i=1
				for action in "${actions[@]}"; do
					if [[ "$action" == "─────────" ]]; then
						echo "  $action"
					else
						echo "  [$i] $action"
						((i++)) || true
					fi
				done
				echo -n "Choice: "
				read -r choice
				local j=0
				for action in "${actions[@]}"; do
					if [[ "$action" != "─────────" ]]; then
						((j++)) || true
						if [[ "$j" == "$choice" ]]; then
							selected_action="$action"
							break
						fi
					fi
				done
				[[ -z "${selected_action:-}" ]] && selected_action="Skip this repo"
			fi

			case "$selected_action" in
			"Review in LazyGit")
				(cd "$repo_path" && lazygit)
				;;
			"Stage all and commit with AI")
				if command -v repo &>/dev/null; then
					(cd "$repo_path" && git add -A && repo commit -s -y)
				else
					print_error "'repo' command not found"
				fi
				;;
			"Backup with timestamp")
				local timestamp
				timestamp=$(date "+%Y-%m-%d %H:%M")
				(cd "$repo_path" && git add -A && git commit -m "backup: $timestamp")
				print_success "Backup commit created"
				;;
			"Cleanup with Claude")
				if command -v claude &>/dev/null; then
					(cd "$repo_path" && claude -p "$DOTS_DIR/common/.claude/commands/dots/git-cleanup.md")
				else
					print_error "'claude' command not found"
				fi
				;;
			"Discard changes")
				if has_gum; then
					if gum confirm "Discard ALL changes in $repo?" --default=false; then
						(cd "$repo_path" && git checkout . && git clean -fd)
						print_success "Changes discarded"
					else
						echo "Cancelled"
					fi
				else
					echo -n "Discard ALL changes in $repo? (y/N) "
					read -r confirm_discard
					if [[ "$confirm_discard" == "y" || "$confirm_discard" == "Y" ]]; then
						(cd "$repo_path" && git checkout . && git clean -fd)
						print_success "Changes discarded"
					else
						echo "Cancelled"
					fi
				fi
				;;
			"Push without committing")
				echo "Skipping commit, will push later..."
				;;
			"Skip this repo")
				echo "Skipping..."
				;;
			"Stop walkthrough")
				echo "Stopping walkthrough"
				break
				;;
			esac

			((current++)) || true
		done
	fi

	# ── Phase 4: Push all repos ──
	echo ""
	log_section "Phase 4: Push all repos"
	echo "Checking for repos to push..."

	local all_to_push=()
	while IFS= read -r repo; do
		[[ -z "$repo" ]] && continue
		local repo_path="$REPOS_BASE_PATH/$repo"

		[[ ! -d "$repo_path/.git" ]] && continue
		# Skip dots (already pushed in Phase 2)
		is_dots_repo "$repo_path" && continue

		if git -C "$repo_path" rev-parse --abbrev-ref '@{u}' &>/dev/null; then
			git -C "$repo_path" fetch --quiet 2>/dev/null || true
			local ahead
			ahead=$(git -C "$repo_path" rev-list --count '@{u}..' 2>/dev/null || echo "0")
			if [[ -n "$ahead" && "$ahead" -gt 0 ]]; then
				all_to_push+=("$repo")
			fi
		fi
	done <<<"$(list_repos)"

	if [[ ${#all_to_push[@]} -eq 0 ]]; then
		log_success "Nothing to push!"
	else
		echo ""
		echo "Repos ready to push:"
		for repo in "${all_to_push[@]}"; do
			local repo_path="$REPOS_BASE_PATH/$repo"
			local ahead
			ahead=$(git -C "$repo_path" rev-list --count '@{u}..' 2>/dev/null || echo "0")
			echo "  * $repo (↑$ahead)"
		done
		echo ""

		local do_push_all=false
		if has_gum; then
			gum confirm "Push all ${#all_to_push[@]} repos?" && do_push_all=true
		else
			echo -n "Push all ${#all_to_push[@]} repos? (y/N) "
			read -r push_confirm
			[[ "$push_confirm" == "y" || "$push_confirm" == "Y" ]] && do_push_all=true
		fi

		if [[ "$do_push_all" == true ]]; then
			for repo in "${all_to_push[@]}"; do
				local repo_path="$REPOS_BASE_PATH/$repo"
				echo "Pushing $repo..."
				if git -C "$repo_path" push 2>/dev/null; then
					print_success "$repo pushed"
				else
					print_error "$repo push failed"
				fi
			done
		else
			echo "Push cancelled"
		fi
	fi

	echo ""
	log_success "Leave complete!"
}

# ── Chores command ──────────────────────────────────────────────
# Commit routine dots repo changes: fonts, themes, sessions, radar, lazy-lock, bookmarks
cmd_chores() {
	log_section "Dots Chores"
	echo ""

	local commits_created=0

	# Font changes (run before theme - if only font changed, commit separately)
	if dots_commit_font "$DOTS_DIR"; then
		((commits_created++)) || true
	fi
	echo ""

	# Theme changes
	if dots_commit_theme "$DOTS_DIR"; then
		((commits_created++)) || true
	fi
	echo ""

	# Session changes (includes cleanup of old sessions)
	if dots_commit_sessions "$DOTS_DIR"; then
		((commits_created++)) || true
	fi
	echo ""

	# Radar changes
	if dots_commit_radar "$DOTS_DIR"; then
		((commits_created++)) || true
	fi
	echo ""

	# Lazy-lock changes
	if dots_commit_lazy_lock "$DOTS_DIR"; then
		((commits_created++)) || true
	fi
	echo ""

	# Bookmarks changes
	if dots_commit_bookmarks "$DOTS_DIR"; then
		((commits_created++)) || true
	fi

	# Summary
	echo ""
	echo "────────────────────────────────────────────────"
	if [[ $commits_created -gt 0 ]]; then
		log_success "Created $commits_created chore commit(s)"
	else
		log_info "No chore commits needed"
	fi

	# Check for remaining uncommitted changes
	local remaining
	remaining=$(git status --porcelain 2>/dev/null)
	if [[ -n "$remaining" ]]; then
		echo ""
		log_warning "Remaining uncommitted changes:"
		git status --short

		# Offer to open lazygit afterwards
		if command -v gum >/dev/null 2>&1; then
			if gum confirm "Open LazyGit?"; then
				lazygit
			fi
		else
			echo -n "Open LazyGit? (y/N) "
			read -r open_lazygit_choice
			if [[ "$open_lazygit_choice" == "y" || "$open_lazygit_choice" == "Y" ]]; then
				lazygit
			fi
		fi
	fi

}

# Function to show usage
show_usage() {
	echo "dots - Dotfiles management command"
	echo ""
	echo "Usage: dots <command> [options]"
	echo ""
	echo "Commands:"
	echo "  state        - Open LazyGit for git status and committing"
	echo "  open         - Open dots directory with \$EDITOR"
	echo ""
	echo "  chores       - Commit routine changes (fonts, themes, sessions, etc.)"
	echo ""
	echo "  pull         - Full sync: pull dots, deps, symlinks, all repos, rebuild"
	echo "                 --hard: force reset diverged/dirty repos"
	echo "                 --rebuild-all: rebuild all tools, not just updated"
	echo "  push         - End of day: chores, commit/push dots, handle dirty repos"
	echo ""
	echo "  link         - Update all symlinks (clean broken + create new)"
	echo "                 --dry-run: preview without making changes"
	echo "                 --no-backup: overwrite existing files"
	echo "                 --verbose: show detailed output"
	echo ""
	echo "  deps         - Install/check dependencies"
	echo "                 check: show dependency status"
	echo "                 install: install missing dependencies"
	echo "                 list: list all dependencies"
	echo ""
	echo "  remove       - Remove path from git tracking (keep files locally)"
	echo ""
	echo "  theme        - Interactive theme selector for all development tools"
	echo "                 --debug: show debug output"
}

# Deps command - install/check dependencies only
cmd_deps() {
	case "${1:-install}" in
	check)
		log_info "Checking dependencies..."
		echo ""
		"$DOTS_DIR/scripts/deps/install.sh" check
		;;
	install)
		log_info "Installing dependencies..."
		echo ""
		"$DOTS_DIR/scripts/deps/install.sh" install
		;;
	list)
		"$DOTS_DIR/scripts/deps/install.sh" list
		;;
	*)
		echo "Usage: dots deps [check|install|list]"
		echo ""
		echo "  check   - Show dependency status"
		echo "  install - Install all missing dependencies (default)"
		echo "  list    - List all dependencies for current OS"
		;;
	esac
}

# Link command
cmd_link() {
	echo "→ Creating symlinks..."
	"$DOTS_DIR/scripts/symlinks.sh" "$@"

	echo ""
	echo "→ Linking Black Atom themes..."
	"$DOTS_DIR/scripts/theme-link.sh" "$@"
}

# Shared push function
do_push() {
	local force_flag="${1:-false}"

	log_info "Pushing to remote..."

	if [[ "$force_flag" == "true" ]]; then
		# Force push directly
		if command -v gum >/dev/null 2>&1; then
			gum spin --spinner="dot" --title="Force pushing..." -- git push --force-with-lease
		else
			git push --force-with-lease
		fi
		log_success "Changes force pushed"
	else
		# Try regular push
		if command -v gum >/dev/null 2>&1; then
			# Capture output to show error message
			local push_output
			if push_output=$(gum spin --spinner="dot" --title="Pushing..." -- git push 2>&1); then
				log_success "Changes pushed"
			else
				log_warning "Push failed:"
				echo "$push_output"
				echo ""
				if gum confirm "Force push with --force-with-lease?"; then
					gum spin --spinner="dot" --title="Force pushing..." -- git push --force-with-lease
					log_success "Changes force pushed"
				else
					log_error "Push cancelled"
					return 1
				fi
			fi
		else
			# Capture output to show error message
			local push_output
			if push_output=$(git push 2>&1); then
				log_success "Changes pushed"
			else
				log_warning "Push failed:"
				echo "$push_output"
				echo "Try: git push --force-with-lease"
				return 1
			fi
		fi
	fi
}

# State command - opens LazyGit
cmd_state() {
	if command -v lazygit >/dev/null 2>&1; then
		lazygit
	else
		log_error "LazyGit not found. Install with: brew install lazygit"
		return 1
	fi
}

# Open command - open dots directory with $EDITOR
cmd_open() {
	# Check if EDITOR is set
	if [[ -z "$EDITOR" ]]; then
		echo "⚠ EDITOR environment variable not set, using 'vim' as default"
		local editor="vim"
	else
		local editor="$EDITOR"
	fi

	echo "→ Opening dots directory with $editor..."
	"$editor" "$DOTS_DIR"
}

# Remove command - remove files from git tracking but keep them locally
cmd_remove() {
	if [[ $# -lt 1 ]]; then
		log_error "Usage: dots remove <path>"
		echo "       Removes path from git tracking and adds to .gitignore"
		return 1
	fi

	local path="$1"

	# Make path relative to dots directory
	if [[ "$path" = /* ]]; then
		path="${path#$DOTS_DIR/}"
	fi

	# Check if path exists
	if [[ ! -e "$path" ]]; then
		log_error "Path does not exist: $path"
		return 1
	fi

	log_info "Removing from git tracking: $path"

	# Check if the path is currently tracked
	if git ls-files --error-unmatch "$path" >/dev/null 2>&1; then
		# Remove from git tracking
		if [[ -d "$path" ]]; then
			if ! git rm --cached -r "$path" 2>/dev/null; then
				log_error "Failed to remove directory from git tracking"
				return 1
			fi
		else
			if ! git rm --cached "$path" 2>/dev/null; then
				log_error "Failed to remove file from git tracking"
				return 1
			fi
		fi
		log_success "Removed from git tracking"
	else
		log_warning "Path is not tracked by git"
	fi

	# Add to .gitignore
	log_info "Adding to .gitignore..."

	# Ensure path ends with / for directories
	local gitignore_entry="$path"
	if [[ -d "$path" ]] && [[ ! "$gitignore_entry" = */ ]]; then
		gitignore_entry="${gitignore_entry}/"
	fi

	# Check if already in .gitignore
	if grep -Fxq "$gitignore_entry" .gitignore 2>/dev/null; then
		log_info "Already in .gitignore"
	else
		# Add to .gitignore
		if [[ -f .gitignore ]]; then
			# Ensure .gitignore ends with newline
			if [[ -n "$(tail -c 1 .gitignore 2>/dev/null)" ]]; then
				echo "" >>.gitignore
			fi
		fi
		echo "$gitignore_entry" >>.gitignore
		log_success "Added to .gitignore"
	fi

	# Stage .gitignore changes
	git add .gitignore

	# Show status
	echo ""
	log_section "Changes ready to commit:"
	git status --short | grep -E "^(M|D|A)" | head -10

	echo ""
	log_info "Files still exist locally at: $DOTS_DIR/$path"

	if command -v gum >/dev/null 2>&1; then
		echo ""
		if gum confirm "Commit these changes now?"; then
			local commit_msg="chore: remove $path from git tracking"
			git commit -m "$commit_msg"
			log_success "Changes committed"
		else
			log_info "Run 'dots commit' when ready to commit"
		fi
	else
		echo ""
		log_info "Run 'dots commit' to commit these changes"
	fi
}

# Main command dispatcher
case "${1:-}" in
deps)
	shift
	cmd_deps "$@"
	;;
link)
	shift
	cmd_link "$@"
	;;
state)
	cmd_state
	;;
open)
	cmd_open
	;;
remove)
	shift
	cmd_remove "$@"
	;;
theme)
	# Return to original directory before running pick-theme
	cd "$ORIGINAL_PWD"
	exec pick-theme "$@"
	;;
pull)
	shift
	cmd_pull "$@"
	;;
push)
	shift
	cmd_push "$@"
	;;
chores)
	cmd_chores
	;;
*)
	show_usage
	;;
esac
