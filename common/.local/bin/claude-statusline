#!/usr/bin/env bash
# Claude Code statusline script
# Responsive layout (breakpoint: 100 cols)
# Wide:  path / git │ commit │ PR link / model │ Ctx bar │ 5h bar │ 7d bar
# Narrow: path / git │ commit / PR link / model / Limits: Ctx │ 5h │ 7d

# Read JSON input from Claude Code
input=$(cat)

# Extract data
dir=$(echo "$input" | jq -r '.workspace.current_dir')
model=$(echo "$input" | jq -r '.model.display_name // "unknown"')
duration_ms=$(echo "$input" | jq -r '.cost.total_duration_ms // 0')
transcript=$(echo "$input" | jq -r '.transcript_path // ""')
context_max=$(echo "$input" | jq -r '.context_window.context_window_size // 1')

# Calculate actual context from current_usage
# Formula: input_tokens + cache_read + cache_creation
input_tok=$(echo "$input" | jq -r '.context_window.current_usage.input_tokens // 0')
cache_read=$(echo "$input" | jq -r '.context_window.current_usage.cache_read_input_tokens // 0')
cache_create=$(echo "$input" | jq -r '.context_window.current_usage.cache_creation_input_tokens // 0')
context_used=$((input_tok + cache_read + cache_create))

# Count compactions from transcript
compactions=0
if [ -n "$transcript" ] && [ -f "$transcript" ]; then
	compactions=$(grep -c '"subtype":"compact_boundary"' "$transcript" 2>/dev/null || echo "0")
fi

# Format duration (ms to human readable)
if [ "$duration_ms" -gt 0 ] 2>/dev/null; then
	total_secs=$((duration_ms / 1000))
	hours=$((total_secs / 3600))
	mins=$(((total_secs % 3600) / 60))
	secs=$((total_secs % 60))
	if [ "$hours" -gt 0 ]; then
		duration="${hours}h${mins}m"
	elif [ "$mins" -gt 0 ]; then
		duration="${mins}m${secs}s"
	else
		duration="${secs}s"
	fi
fi

# Git info
branch=$(git -C "$dir" branch --show-current 2>/dev/null)

# Git status: diff stats (insertions/deletions/modified files)
git_summary=""
if [ -n "$branch" ]; then
	# Count changed files and line stats
	staged_files=$(git -C "$dir" diff --cached --numstat 2>/dev/null)
	unstaged_files=$(git -C "$dir" diff --numstat 2>/dev/null)
	untracked=$(git -C "$dir" ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')

	# Combine staged + unstaged for total stats
	all_changes=$(printf '%s\n%s' "$staged_files" "$unstaged_files" | grep -v '^$')
	if [ -n "$all_changes" ]; then
		added=$(echo "$all_changes" | awk '{s+=$1} END {print s+0}')
		deleted=$(echo "$all_changes" | awk '{s+=$2} END {print s+0}')
		changed=$(echo "$all_changes" | wc -l | tr -d ' ')
		total_files=$((changed + untracked))

		parts="${total_files} changed"
		[ "$added" -gt 0 ] && parts="${parts}, +${added}"
		[ "$deleted" -gt 0 ] && parts="${parts}, -${deleted}"
		[ "$untracked" -gt 0 ] && parts="${parts}, ${untracked} new"
		git_branch="\033[32m\ue725 ${branch}\033[0m"
		git_stats="\033[90m${parts}\033[0m"
	elif [ "$untracked" -gt 0 ]; then
		git_branch="\033[32m\ue725 ${branch}\033[0m"
		git_stats="\033[90m${untracked} new\033[0m"
	else
		git_branch="\033[32m\ue725 ${branch}\033[0m"
		git_stats="\033[90mclean\033[0m"
	fi
fi

# Last commit message (truncated in wide mode only)
last_commit=$(git -C "$dir" log -1 --format='%s' 2>/dev/null)

# Context progress bar + token counts
if [ "$context_max" -gt 0 ] 2>/dev/null; then
	percent=$((context_used * 100 / context_max))
	bar_width=10
	filled=$((percent * bar_width / 100))
	# Show at least 1 block if there's any usage
	[ "$percent" -gt 0 ] && [ "$filled" -eq 0 ] && filled=1
	empty=$((bar_width - filled))

	# Color based on usage: green < 50%, yellow 50-75%, red > 75%
	if [ "$percent" -lt 50 ]; then
		bar_color="\033[32m"
	elif [ "$percent" -lt 75 ]; then
		bar_color="\033[33m"
	else
		bar_color="\033[31m"
	fi

	bar="${bar_color}"
	for ((i = 0; i < filled; i++)); do bar+="█"; done
	bar+="\033[90m"
	for ((i = 0; i < empty; i++)); do bar+="░"; done
	bar+="\033[0m"

	# Token counts as rounded k values
	used_k=$(((context_used + 500) / 1000))
	max_k=$(((context_max + 500) / 1000))
fi

# Separator
sep="\033[90m │ \033[0m"

# Shorten home directory to ~
display_dir="${dir/#$HOME/\~}"

# PR title (cached per repo+branch, background fetch)
PR_CACHE="/tmp/claude-statusline-pr-$(echo "${dir}:${branch}" | md5 -q).json"
PR_CACHE_TTL=120

fetch_pr() {
	local pr_json
	pr_json=$(gh pr view --json title,number,state,url --jq 'select(.state == "OPEN") | "\(.number)\t\(.url)\t\(.title)"' 2>/dev/null) || return 1
	[ -z "$pr_json" ] && return 1
	echo "$pr_json" >"$PR_CACHE"
}

pr_number=""
pr_url=""

# Only fetch/show PR info on non-default branches
if [ -n "$branch" ] && [ "$branch" != "main" ] && [ "$branch" != "master" ]; then
	# Refresh cache if stale (background)
	if [ ! -f "$PR_CACHE" ] || [ $(($(date +%s) - $(stat -f%m "$PR_CACHE" 2>/dev/null || echo 0))) -gt $PR_CACHE_TTL ]; then
		(cd "$dir" && fetch_pr) 2>/dev/null &
	fi

	if [ -f "$PR_CACHE" ]; then
		pr_number=$(cut -f1 "$PR_CACHE" 2>/dev/null)
		pr_url=$(cut -f2 "$PR_CACHE" 2>/dev/null)
	fi
fi

# Terminal width for responsive layout (tmux pane width, fallback to tput)
# Claude Code's statusline area is narrower than pane_width due to internal chrome (~30 cols)
cols=$(tmux display-message -p '#{pane_width}' 2>/dev/null || tput cols 2>/dev/null || echo 80)
wide=true
[ "$cols" -lt 180 ] && wide=false

# --- Line 1: path ---
printf '\033[1;90m%s\033[0m' "$display_dir"

# --- Git status + commit + optional PR link ---
if [ -n "$git_branch" ]; then
	printf '\n'
	if $wide; then
		# Wide: everything on one line
		printf '\033[90m%-15s\033[0m%b\033[90m │ \033[0m%b' "Git" "$git_branch" "$git_stats"
		if [ -n "$last_commit" ]; then
			wide_commit="$last_commit"
			[ "${#wide_commit}" -gt 30 ] && wide_commit="${wide_commit:0:27}..."
			printf '\033[90m │ %s\033[0m' "$wide_commit"
		fi
		[ -n "$pr_number" ] && [ -n "$pr_url" ] && printf '%b%s' "$sep" "$pr_url"
	else
		# Narrow: each section on its own line
		printf '\033[90m%-15s\033[0m%b' "Branch" "$git_branch"
		printf '\n'
		printf '\033[90m%-15s\033[0m%b' "Changes" "$git_stats"
		if [ -n "$last_commit" ]; then
			printf '\n'
			printf '\033[90m%-15s%s\033[0m' "Last Commit" "$last_commit"
		fi
		if [ -n "$pr_number" ] && [ -n "$pr_url" ]; then
			printf '\n'
			printf '\033[90m%-15s\033[0m%s' "PR" "$pr_url"
		fi
	fi
fi

# Build usage bar (same style as context bar)
usage_bar() {
	local pct=$1 width=10
	local fill=$((pct * width / 100))
	[ "$pct" -gt 0 ] && [ "$fill" -eq 0 ] && fill=1
	[ "$fill" -gt "$width" ] && fill=$width
	local emp=$((width - fill))

	local color
	if [ "$pct" -lt 50 ]; then
		color="\033[32m"
	elif [ "$pct" -lt 75 ]; then
		color="\033[33m"
	else
		color="\033[31m"
	fi

	printf '%b' "$color"
	for ((i = 0; i < fill; i++)); do printf '█'; done
	printf '\033[90m'
	for ((i = 0; i < emp; i++)); do printf '░'; done
	printf '\033[0m'
}

# Format Unix epoch reset time to human-readable relative string
format_reset() {
	local epoch=$1
	local now
	now=$(date +%s)
	local diff=$((epoch - now))

	if [ "$diff" -le 0 ]; then
		printf 'now'
	elif [ "$diff" -lt 3600 ]; then
		printf '%dm' $((diff / 60))
	elif [ "$diff" -lt 86400 ]; then
		date -r "$epoch" "+%H:%M" 2>/dev/null
	else
		date -r "$epoch" "+%b %-d, %H:%M" 2>/dev/null
	fi
}

u5=$(echo "$input" | jq -r '.rate_limits.five_hour.used_percentage // empty' 2>/dev/null)
r5=$(echo "$input" | jq -r '.rate_limits.five_hour.resets_at // empty' 2>/dev/null)
u7=$(echo "$input" | jq -r '.rate_limits.seven_day.used_percentage // empty' 2>/dev/null)
r7=$(echo "$input" | jq -r '.rate_limits.seven_day.resets_at // empty' 2>/dev/null)

# --- Model + limits ---
printf '\n'
if [ -n "$model" ] && [ "$model" != "unknown" ]; then
	printf '\033[90m%-15s\033[36m%s\033[0m' "Model" "$model"
fi

if [ "$compactions" -gt 0 ]; then
	if [ "$compactions" -ge 3 ]; then
		comp_color="\033[31m"
	else
		comp_color="\033[33m"
	fi
	printf '%b%bCompacts %sx\033[0m' "$sep" "$comp_color" "$compactions"
fi

if [ "$context_max" -gt 0 ] 2>/dev/null; then
	if $wide; then
		# Wide: all bars on same line as model
		printf '%b' "$sep"
		printf '\033[90mCtx \033[0m'
		printf '%b' "$bar"
		printf '  \033[90m%dk/%dk\033[0m' "$used_k" "$max_k"

		if [ -n "$u5" ]; then
			u5_int=$(printf '%.0f' "$u5")
			printf '%b' "$sep"
			printf '\033[90m5h \033[0m'
			usage_bar "$u5_int"
			if [ -n "$r5" ]; then
				reset_str=$(format_reset "$r5")
				[ -n "$reset_str" ] && printf '  \033[90m↺%s\033[0m' "$reset_str"
			fi
		fi

		if [ -n "$u7" ]; then
			u7_int=$(printf '%.0f' "$u7")
			printf '%b' "$sep"
			printf '\033[90m7d \033[0m'
			usage_bar "$u7_int"
			if [ -n "$r7" ]; then
				reset_str=$(format_reset "$r7")
				[ -n "$reset_str" ] && printf '  \033[90m↺%s\033[0m' "$reset_str"
			fi
		fi
	else
		# Narrow: each bar on its own line
		printf '\n'
		printf '\033[90m%-15s\033[0m' "Context"
		printf '%b' "$bar"
		printf '  \033[90m%dk/%dk\033[0m' "$used_k" "$max_k"

		if [ -n "$u5" ]; then
			u5_int=$(printf '%.0f' "$u5")
			printf '\n'
			printf '\033[90m%-15s\033[0m' "Current Limit"
			usage_bar "$u5_int"
			if [ -n "$r5" ]; then
				reset_str=$(format_reset "$r5")
				[ -n "$reset_str" ] && printf '  \033[90m↺%s\033[0m' "$reset_str"
			fi
		fi

		if [ -n "$u7" ]; then
			u7_int=$(printf '%.0f' "$u7")
			printf '\n'
			printf '\033[90m%-15s\033[0m' "Weekly Limit"
			usage_bar "$u7_int"
			if [ -n "$r7" ]; then
				reset_str=$(format_reset "$r7")
				[ -n "$reset_str" ] && printf '  \033[90m↺%s\033[0m' "$reset_str"
			fi
		fi
	fi
fi
