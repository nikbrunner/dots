#!/usr/bin/env bash
# Claude Code statusline script
# 4-line layout:
#   Line 1: project path │ git branch
#   Line 2: model │ duration │ compactions
#   Line 3: context bar │ percentage │ token counts
#   Line 4: 5hr usage │ 7-day usage (from OAuth API, cached 60s)

# Read JSON input from Claude Code
input=$(cat)

# Extract data
dir=$(echo "$input" | jq -r '.workspace.current_dir')
model=$(echo "$input" | jq -r '.model.display_name // "unknown"')
duration_ms=$(echo "$input" | jq -r '.cost.total_duration_ms // 0')
transcript=$(echo "$input" | jq -r '.transcript_path // ""')
context_max=$(echo "$input" | jq -r '.context_window.context_window_size // 1')

# Calculate actual context from current_usage
# Formula: input_tokens + cache_read + cache_creation
input_tok=$(echo "$input" | jq -r '.context_window.current_usage.input_tokens // 0')
cache_read=$(echo "$input" | jq -r '.context_window.current_usage.cache_read_input_tokens // 0')
cache_create=$(echo "$input" | jq -r '.context_window.current_usage.cache_creation_input_tokens // 0')
context_used=$((input_tok + cache_read + cache_create))

# Count compactions from transcript
compactions=0
if [ -n "$transcript" ] && [ -f "$transcript" ]; then
	compactions=$(grep -c '"subtype":"compact_boundary"' "$transcript" 2>/dev/null || echo "0")
fi

# Format duration (ms to human readable)
if [ "$duration_ms" -gt 0 ] 2>/dev/null; then
	total_secs=$((duration_ms / 1000))
	hours=$((total_secs / 3600))
	mins=$(((total_secs % 3600) / 60))
	secs=$((total_secs % 60))
	if [ "$hours" -gt 0 ]; then
		duration="${hours}h${mins}m"
	elif [ "$mins" -gt 0 ]; then
		duration="${mins}m${secs}s"
	else
		duration="${secs}s"
	fi
fi

# Git branch
branch=$(git -C "$dir" branch --show-current 2>/dev/null)

# Context progress bar + token counts
if [ "$context_max" -gt 0 ] 2>/dev/null; then
	percent=$((context_used * 100 / context_max))
	bar_width=10
	filled=$((percent * bar_width / 100))
	# Show at least 1 block if there's any usage
	[ "$percent" -gt 0 ] && [ "$filled" -eq 0 ] && filled=1
	empty=$((bar_width - filled))

	# Color based on usage: green < 50%, yellow 50-75%, red > 75%
	if [ "$percent" -lt 50 ]; then
		bar_color="\033[32m"
	elif [ "$percent" -lt 75 ]; then
		bar_color="\033[33m"
	else
		bar_color="\033[31m"
	fi

	bar="${bar_color}"
	for ((i = 0; i < filled; i++)); do bar+="█"; done
	bar+="\033[90m"
	for ((i = 0; i < empty; i++)); do bar+="░"; done
	bar+="\033[0m"

	# Token counts as rounded k values
	used_k=$(( (context_used + 500) / 1000 ))
	max_k=$(( (context_max + 500) / 1000 ))
fi

# Separator
sep="\033[90m │ \033[0m"

# Shorten home directory to ~
display_dir="${dir/#$HOME/\~}"

# --- Line 1: path │ git branch ---
printf '\033[90m%s\033[0m' "$display_dir"
[ -n "$branch" ] && printf '%b\033[32m\ue725 %s\033[0m' "$sep" "$branch"

# --- Line 2: model │ duration │ compactions ---
printf '\n'
[ -n "$model" ] && [ "$model" != "unknown" ] && printf '\033[36m%s\033[0m' "$model"

[ -n "$duration" ] && printf '%b\033[35m%s\033[0m' "$sep" "$duration"

if [ "$compactions" -gt 0 ]; then
	if [ "$compactions" -ge 3 ]; then
		comp_color="\033[31m"
	else
		comp_color="\033[33m"
	fi
	printf '%b%b⚠ %sx compact\033[0m' "$sep" "$comp_color" "$compactions"
fi

# --- Line 3: context bar │ percentage │ token counts ---
if [ "$context_max" -gt 0 ] 2>/dev/null; then
	printf '\n'
	printf '\033[90m%-15s\033[0m' "Context"
	printf '%b' "$bar"

	if [ "$percent" -ge 75 ]; then
		printf ' \033[31m%3d%%\033[0m  \033[31m⛽\033[0m' "$percent"
	else
		printf ' %3d%%' "$percent"
	fi

	printf '  \033[90m%dk / %dk Tokens\033[0m' "$used_k" "$max_k"
fi

# --- Lines 4-5: 5hr and 7-day usage (OAuth API with caching) ---
USAGE_CACHE="/tmp/claude-statusline-usage.json"
USAGE_CACHE_TTL=60

fetch_usage() {
	local creds token response
	creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || return 1
	token=$(echo "$creds" | jq -r '.claudeAiOauth.accessToken') || return 1
	[ -z "$token" ] || [ "$token" = "null" ] && return 1
	response=$(curl -s --max-time 3 "https://api.anthropic.com/api/oauth/usage" \
		-H "Authorization: Bearer $token" \
		-H "anthropic-beta: oauth-2025-04-20" \
		-H "Content-Type: application/json" 2>/dev/null) || return 1
	echo "$response" | jq -e '.five_hour' >/dev/null 2>&1 || return 1
	echo "$response" >"$USAGE_CACHE"
}

# Refresh cache if stale
if [ ! -f "$USAGE_CACHE" ] || [ $(($(date +%s) - $(stat -f%m "$USAGE_CACHE" 2>/dev/null || echo 0))) -gt $USAGE_CACHE_TTL ]; then
	fetch_usage 2>/dev/null &
fi

# Build usage bar (same style as context bar)
usage_bar() {
	local pct=$1 width=10
	local fill=$((pct * width / 100))
	[ "$pct" -gt 0 ] && [ "$fill" -eq 0 ] && fill=1
	[ "$fill" -gt "$width" ] && fill=$width
	local emp=$((width - fill))

	local color
	if [ "$pct" -lt 50 ]; then
		color="\033[32m"
	elif [ "$pct" -lt 75 ]; then
		color="\033[33m"
	else
		color="\033[31m"
	fi

	printf '%b' "$color"
	for ((i = 0; i < fill; i++)); do printf '█'; done
	printf '\033[90m'
	for ((i = 0; i < emp; i++)); do printf '░'; done
	printf '\033[0m'
}

# Format ISO reset time to local human-readable
format_reset() {
	local iso=$1
	# Strip fractional seconds and timezone for macOS date parsing
	local clean
	clean=$(echo "$iso" | sed 's/\.[0-9]*+/ +/' | sed 's/+\([0-9][0-9]\):\([0-9][0-9]\)/+\1\2/')
	local epoch
	epoch=$(date -jf "%Y-%m-%dT%H:%M:%S %z" "$clean" +%s 2>/dev/null) || return 1
	local now
	now=$(date +%s)
	local diff=$((epoch - now))

	if [ "$diff" -le 0 ]; then
		printf 'now'
	elif [ "$diff" -lt 3600 ]; then
		printf '%dm' $((diff / 60))
	elif [ "$diff" -lt 86400 ]; then
		# Today or soon — show time
		date -jf "%Y-%m-%dT%H:%M:%S %z" "$clean" "+%-I:%M%p" 2>/dev/null | tr '[:upper:]' '[:lower:]'
	else
		# Further out — show date + time
		date -jf "%Y-%m-%dT%H:%M:%S %z" "$clean" "+%b %-d, %-I:%M%p" 2>/dev/null | tr '[:upper:]' '[:lower:]'
	fi
}

if [ -f "$USAGE_CACHE" ]; then
	u5=$(jq -r '.five_hour.utilization // empty' "$USAGE_CACHE" 2>/dev/null | cut -d. -f1)
	u7=$(jq -r '.seven_day.utilization // empty' "$USAGE_CACHE" 2>/dev/null | cut -d. -f1)
	r5=$(jq -r '.five_hour.resets_at // empty' "$USAGE_CACHE" 2>/dev/null)
	r7=$(jq -r '.seven_day.resets_at // empty' "$USAGE_CACHE" 2>/dev/null)

	if [ -n "$u5" ]; then
		printf '\n'
		printf '\033[90m%-15s\033[0m' "Current Limit"
		usage_bar "$u5"
		printf ' %3d%%' "$u5"
		if [ -n "$r5" ]; then
			reset_str=$(format_reset "$r5")
			[ -n "$reset_str" ] && printf '  \033[90mresets %s\033[0m' "$reset_str"
		fi
	fi

	if [ -n "$u7" ]; then
		printf '\n'
		printf '\033[90m%-15s\033[0m' "Weekly Limit"
		usage_bar "$u7"
		printf ' %3d%%' "$u7"
		if [ -n "$r7" ]; then
			reset_str=$(format_reset "$r7")
			[ -n "$reset_str" ] && printf '  \033[90mresets %s\033[0m' "$reset_str"
		fi
	fi
fi
