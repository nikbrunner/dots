#!/usr/bin/env bash
set -e

if ! command -v pass-cli &>/dev/null; then
	echo "error: pass-cli not found" >&2
	exit 1
fi

if ! pass-cli test &>/dev/null; then
	echo "error: pass-cli not authenticated" >&2
	exit 1
fi

# Find all items starting with ".env" and sync each to ~/.<name>
pass-cli item list --filter-type custom --output json |
	jq -r '.items[] | select(.content.title | startswith(".env")) | .content.title' |
	while read -r title; do
		out_file="$HOME/$title"
		pass-cli item view --item-title="$title" --output=json |
			jq -r '.item.content.extra_fields[] | select(.content.Hidden) | "\(.name)=\(.content.Hidden)"' >"$out_file"
		chmod 600 "$out_file"
		echo "synced $(wc -l <"$out_file" | tr -d ' ') vars to $out_file"
	done

# Reload shell if running interactively
[[ -t 0 ]] && exec zsh

exec zsh
