#!/bin/bash

# pick-theme - Unified theme selector for all development tools
# Uses fzf to select from Black Atom themes and updates configurations

set -uo pipefail

# Run a step and track failures without aborting
errors=()
PROGRESS_CURRENT=0
PROGRESS_TOTAL=0

draw_progress() {
	local width=20
	local filled=$((PROGRESS_CURRENT * width / PROGRESS_TOTAL))
	local bar=""
	for ((i = 0; i < width; i++)); do
		if ((i < filled)); then bar+="#"; else bar+=" "; fi
	done
	# Clear entire line (catches Ghostty escape sequences)
	printf "\r\033[K[%s]" "$bar"
}

run_step() {
	local label="$1"
	shift
	PROGRESS_CURRENT=$((PROGRESS_CURRENT + 1))
	# draw_progress
	if ! "$@" >/dev/null 2>&1; then
		errors+=("$label")
	fi
}

# Configuration
DOTS_DIR="${DOTS_DIR:-$HOME/repos/nikbrunner/dots}"
THEMES_JSON="$DOTS_DIR/common/themes.json"

# Tool configurations
NVIM_CONFIG="$DOTS_DIR/common/.config/nvim/lua/config.lua"
TMUX_CONFIG="$DOTS_DIR/common/.config/tmux/tmux.conf"
GHOSTTY_CONFIG="$DOTS_DIR/common/.config/ghostty/config"
GIT_DELTA_CONFIG="$DOTS_DIR/common/.gitconfig.delta"
ZED_CONFIG="$DOTS_DIR/common/.config/zed/settings.json"
NIRI_THEME_LINK="$DOTS_DIR/arch/.config/niri/theme.kdl"
WAYBAR_THEME="$HOME/.config/waybar/theme.css"
WAYBAR_THEMES_DIR="$HOME/.config/waybar/themes"
LAZYGIT_CONFIG="$DOTS_DIR/common/.config/lazygit/config.yml"
LAZYGIT_THEMES_DIR="$DOTS_DIR/common/.config/lazygit/themes"
HELM_CONFIG="$DOTS_DIR/common/.config/black-atom/helm/config.yml"

# Get current theme from nvim config
get_current_theme() {
	grep "colorscheme" "$NVIM_CONFIG" | sed 's/.*= *"//' | sed 's/".*//'
}

# Get current background mode from macOS system
get_current_mode() {
	if [[ "$(uname)" == "Darwin" ]]; then
		if defaults read -g AppleInterfaceStyle 2>/dev/null | grep -q "Dark"; then
			echo "dark"
		else
			echo "light"
		fi
	else
		# Default to dark on non-macOS systems
		echo "dark"
	fi
}

# Get theme metadata (appearance and collection)
get_theme_metadata() {
	local theme="$1"
	jq -r ".themes.\"$theme\" | [.appearance, .collection] | @tsv" "$THEMES_JSON"
}

# Update Neovim configuration
update_nvim_theme() {
	local theme="$1"
	if [[ "$(uname)" == "Darwin" ]]; then
		sed -i '' "s/colorscheme = .*/colorscheme = \"$theme\",/" "$NVIM_CONFIG"
	else
		sed -i "s/colorscheme = .*/colorscheme = \"$theme\",/" "$NVIM_CONFIG"
	fi
}

# Update tmux configuration
update_tmux_theme() {
	local theme="$1"
	local collection="$2"
	local theme_path="~/repos/black-atom-industries/tmux/themes/$collection/${theme}.conf"
	if [[ "$(uname)" == "Darwin" ]]; then
		sed -i '' "s|source-file .*/black-atom-industries/tmux/themes/.*/.*\.conf|source-file $theme_path|" "$TMUX_CONFIG"
	else
		sed -i "s|source-file .*/black-atom-industries/tmux/themes/.*/.*\.conf|source-file $theme_path|" "$TMUX_CONFIG"
	fi
}

# Update Ghostty configuration
update_ghostty_theme() {
	local theme="$1"
	if [[ "$(uname)" == "Darwin" ]]; then
		sed -i '' "s/^theme = .*/theme = ${theme}.conf/" "$GHOSTTY_CONFIG"
	else
		sed -i "s/^theme = .*/theme = ${theme}.conf/" "$GHOSTTY_CONFIG"
	fi
}

# Update Zed configuration
update_zed_theme() {
	local theme="$1"
	local display_name
	display_name=$(jq -r ".themes.\"$theme\".display_name" "$THEMES_JSON")

	if [[ -z "$display_name" || "$display_name" == "null" ]]; then
		echo "Zed theme display name not found for $theme, skipping"
		return 0
	fi

	if [[ "$(uname)" == "Darwin" ]]; then
		sed -i '' "s/\"theme\": \".*\"/\"theme\": \"$display_name\"/" "$ZED_CONFIG"
	else
		sed -i "s/\"theme\": \".*\"/\"theme\": \"$display_name\"/" "$ZED_CONFIG"
	fi
}

# Update Git delta configuration
update_delta_theme() {
	local appearance="$1"
	local features_line features_target
	if [[ "$appearance" == "dark" ]]; then
		features_line="    features = black-atom-dark"
		features_target="    features = black-atom-light"
	else
		features_line="    features = black-atom-light"
		features_target="    features = black-atom-dark"
	fi
	if [[ "$(uname)" == "Darwin" ]]; then
		sed -i '' "s/$features_target/$features_line/" "$GIT_DELTA_CONFIG"
	else
		sed -i "s/$features_target/$features_line/" "$GIT_DELTA_CONFIG"
	fi
}

# Update Niri theme (Linux/Wayland only)
update_niri_theme() {
	# Skip on macOS - niri is Linux/Wayland only
	[[ "$(uname)" == "Darwin" ]] && return 0

	local theme="$1"
	local collection="$2"
	local theme_source="$HOME/repos/black-atom-industries/niri/themes/$collection/${theme}.kdl"

	# Only update if niri config directory exists
	if [[ -d "$(dirname "$NIRI_THEME_LINK")" ]]; then
		ln -sfr "$theme_source" "$NIRI_THEME_LINK"
		echo "niri theme updated"
	fi
}

# Update Waybar theme (Linux/Wayland only)
update_waybar_theme() {
	# Skip on macOS - waybar is Linux/Wayland only
	[[ "$(uname)" == "Darwin" ]] && return 0

	local theme="$1"

	# Only update if waybar themes directory exists
	if [[ -d "$WAYBAR_THEMES_DIR" ]]; then
		ln -sf "themes/${theme}.css" "$WAYBAR_THEME"
		echo "waybar theme updated"
	fi
}

# Update helm appearance config (requires yq)
update_helm_theme() {
	local appearance="$1"

	if ! command -v yq >/dev/null 2>&1; then
		echo "yq not installed, skipping helm theme update"
		return 0
	fi

	if [[ ! -f "$HELM_CONFIG" ]]; then
		echo "helm config not found: $HELM_CONFIG"
		return 0
	fi

	yq -i ".appearance = \"$appearance\"" "$HELM_CONFIG"
	echo "helm appearance updated to $appearance"
}

# Update lazygit theme (requires yq)
update_lazygit_theme() {
	local theme="$1"
	local theme_file="$LAZYGIT_THEMES_DIR/${theme}.yml"

	if ! command -v yq >/dev/null 2>&1; then
		echo "yq not installed, skipping lazygit theme update"
		return 0
	fi

	if [[ ! -f "$theme_file" ]]; then
		echo "lazygit theme not found: $theme_file"
		return 0
	fi

	# Use yq load() to properly merge YAML structures
	yq -i ".gui.theme = load(\"$theme_file\").gui.theme" "$LAZYGIT_CONFIG"
	yq -i ".gui.authorColors = load(\"$theme_file\").gui.authorColors" "$LAZYGIT_CONFIG"

	echo "lazygit theme updated"
}

# Reload Waybar stylesheet (Linux/Wayland only)
reload_waybar() {
	[[ "$(uname)" == "Darwin" ]] && return 0

	if pgrep -x waybar >/dev/null 2>&1; then
		killall -SIGUSR2 waybar 2>/dev/null && echo "waybar styles reloaded"
	fi
}

# Update macOS system appearance
update_macos_appearance() {
	local appearance="$1"
	if [[ "$(uname)" == "Darwin" ]]; then
		if [[ "$appearance" == "dark" ]]; then
			osascript -e 'tell application "System Events" to tell appearance preferences to set dark mode to true' 2>/dev/null && echo "macOS switched to dark mode"
		else
			osascript -e 'tell application "System Events" to tell appearance preferences to set dark mode to false' 2>/dev/null && echo "macOS switched to light mode"
		fi
	fi
}

# Reload tmux configuration if tmux is running
reload_tmux() {
	if command -v tmux >/dev/null 2>&1 && tmux list-sessions >/dev/null 2>&1; then
		if tmux source-file "$TMUX_CONFIG" 2>/dev/null; then
			echo "tmux configuration reloaded"
		fi
	fi
}

# Source shared Ghostty reload function
source "$DOTS_DIR/common/.local/bin/ghostty-reload"

# Restart Neovim instances via server sockets (no tmux dependency)
restart_neovim_instances() {
	local theme
	theme=$(get_current_theme)

	local tmpdir="${TMPDIR:-/tmp}"
	local nvim_dir="$tmpdir/nvim.$USER"

	if [[ ! -d "$nvim_dir" ]]; then
		echo "No nvim server sockets found in $nvim_dir"
		return 0
	fi

	local sockets=()
	while IFS= read -r socket; do
		sockets+=("$socket")
	done < <(find "$nvim_dir" -maxdepth 3 -name 'nvim.*' -type s 2>/dev/null || true)

	if [[ ${#sockets[@]} -eq 0 ]]; then
		echo "No nvim server sockets found"
		return 0
	fi

	echo "Sending :colorscheme $theme to ${#sockets[@]} Neovim instances..."

	local sent=0 stale=0 failed=0
	for socket in "${sockets[@]}"; do
		if nvim --server "$socket" --remote-send ":colorscheme $theme<CR>" 2>/dev/null; then
			sent=$((sent + 1))
		else
			# Non-zero exit means stale socket
			stale=$((stale + 1))
		fi
	done

	if [[ $sent -gt 0 ]]; then
		echo "Updated $sent Neovim instances"
	fi
	if [[ $stale -gt 0 ]]; then
		echo "$stale stale socket(s) skipped"
	fi
}

# Apply theme to all tools
apply_theme() {
	local theme="$1"

	# Get and validate theme metadata
	local metadata appearance collection
	metadata=$(get_theme_metadata "$theme")

	if [[ -z "$metadata" || "$metadata" == *"null"* ]]; then
		echo "Error: Theme '$theme' not found"
		return 1
	fi

	read -r appearance collection <<<"$metadata"

	echo "Applying: $theme ($appearance)"
	echo ""

	errors=()

	errors=()
	PROGRESS_CURRENT=0
	PROGRESS_TOTAL=14

	# Update config files
	run_step "nvim config" update_nvim_theme "$theme"
	run_step "tmux config" update_tmux_theme "$theme" "$collection"
	run_step "ghostty config" update_ghostty_theme "$theme"
	run_step "zed config" update_zed_theme "$theme"
	run_step "delta config" update_delta_theme "$appearance"
	run_step "niri config" update_niri_theme "$theme" "$collection"
	run_step "waybar config" update_waybar_theme "$theme"
	run_step "lazygit config" update_lazygit_theme "$theme"
	run_step "helm config" update_helm_theme "$appearance"
	run_step "macOS appearance" update_macos_appearance "$appearance"

	# sleep 0.2

	# Reload configurations (ghostty deferred — writes escape sequences)
	run_step "tmux reload" reload_tmux
	run_step "waybar reload" reload_waybar

	# Apply theme to running Neovim instances via server sockets
	run_step "neovim reload" restart_neovim_instances

	# Clear progress bar line
	# printf "\r%s\r" "                                        "

	# Ghostty reload last — escape sequences print after output
	# stty -echo 2>/dev/null || true
	# run_step "ghostty reload" reload_ghostty
	# sleep 0.15
	# stty echo 2>/dev/null || true

	if [[ ${#errors[@]} -gt 0 ]]; then
		echo "${#errors[@]} step(s) failed"
		return 1
	fi
	echo "Done."
}

# Validate dependencies and configuration files
validate_environment() {
	local errors=()

	# Check required commands
	local required_cmds=("jq" "fzf")
	for cmd in "${required_cmds[@]}"; do
		command -v "$cmd" >/dev/null 2>&1 || errors+=("$cmd is required but not installed")
	done

	# Check configuration files
	[[ -f "$THEMES_JSON" ]] || errors+=("Themes registry not found: $THEMES_JSON")
	[[ -f "$NVIM_CONFIG" ]] || errors+=("Neovim config not found: $NVIM_CONFIG")
	[[ -f "$TMUX_CONFIG" ]] || errors+=("tmux config not found: $TMUX_CONFIG")
	[[ -f "$GHOSTTY_CONFIG" ]] || errors+=("Ghostty config not found: $GHOSTTY_CONFIG")
	[[ -f "$GIT_DELTA_CONFIG" ]] || errors+=("Git delta config not found: $GIT_DELTA_CONFIG")

	if [[ ${#errors[@]} -gt 0 ]]; then
		echo "Environment errors:"
		printf "  - %s\n" "${errors[@]}"
		return 1
	fi
}

main() {
	# Validate environment
	validate_environment || exit 1

	# If a theme name is passed as argument, apply directly (skip fzf)
	if [[ $# -gt 0 ]]; then
		apply_theme "$1"
		return $?
	fi

	# Get current state
	local current_theme current_mode
	current_theme=$(get_current_theme)
	current_mode=$(get_current_mode)

	# Get available themes with display names
	local themes_display
	themes_display=$(jq -r '.themes | to_entries[] | "\(.key):\(.value.display_name)"' "$THEMES_JSON")

	if [[ -z "$themes_display" ]]; then
		echo "No themes found in $THEMES_JSON"
		exit 1
	fi

	# Show current state
	echo "Current theme: $current_theme ($current_mode mode)"
	echo

	# Interactive selection with fzf
	local selected_line selected_theme
	selected_line=$(echo "$themes_display" | fzf \
		--border-label="┃ pick-theme ┃" \
		--prompt="Select theme: " \
		--header="Current: $current_theme | Mode: $current_mode" \
		--with-nth=2 \
		--delimiter=":")

	if [[ -n "$selected_line" ]]; then
		selected_theme=$(echo "$selected_line" | cut -d: -f1)

		if [[ "$selected_theme" == "$current_theme" ]]; then
			echo "Theme unchanged: $selected_theme"
		else
			apply_theme "$selected_theme"
		fi
	else
		echo "No theme selected"
	fi
}

main "$@"
