#!/usr/bin/env bash
# ccu — Claude Code cost breakdown per repo, split by imfusion vs personal.
#
# ccusage's --project flag matches basenames only, which collide across
# unrelated repos (e.g. two repos named "web-ui"), so this re-renders
# ccusage's per-project JSON, matching on the full encoded project path
# instead. Repo roots are found on disk so worktrees and subdirectories
# of the same repo fold into one row. Requires gum for table rendering
# (multi-line model cells need gum; plain `column -t` can't align them).
set -e

if ! command -v gum &>/dev/null; then
	echo "ccu: requires 'gum' to render tables (brew install gum)" >&2
	exit 1
fi

usage() {
	cat <<-EOF
		Usage: ccu <command> [ccusage-flags...]

		Commands:
		  imfusion   Cost breakdown for ~/repos/imfusion
		  personal   Cost breakdown excluding ~/repos/imfusion
		  help       Show this help

		Any extra flags are passed through to 'ccusage claude daily'
		(e.g. --since 20260701, --until 20260714).
	EOF
}

cmd="$1"
shift || true

case "$cmd" in
imfusion)
	mode="include"
	prefix="$HOME/repos/imfusion"
	;;
personal)
	mode="exclude"
	prefix="$HOME/repos/imfusion"
	;;
help | --help | -h | "")
	usage
	exit 0
	;;
*)
	echo "ccu: unknown command '$cmd'" >&2
	usage >&2
	exit 1
	;;
esac

marker=$(echo "$prefix" | sed "s|^$HOME|-Users-$(whoami)|; s|/|-|g")

# The Today/Yesterday/This week/Last week/This month summary needs data
# back to the earlier of "start of last week" or "start of this month";
# default --since accordingly unless the caller already passed one.
last_week_start=$(date -v-monday -v-7d +%Y%m%d)
month_start=$(date +%Y%m01)
default_since=$([[ "$last_week_start" < "$month_start" ]] && echo "$last_week_start" || echo "$month_start")
has_since=false
for arg in "$@"; do
	case "$arg" in
	-s | --since) has_since=true ;;
	esac
done
extra_args=("$@")
if [[ "$has_since" == false ]]; then
	extra_args=(--since "$default_since" "${extra_args[@]}")
fi

# Map every known git repo root under $HOME to its ccusage-encoded key
# (real_path\tencoded_key) so we can match project keys back to real repos
# and recover a readable basename.
repo_roots=$(find "$HOME" -maxdepth 6 -type d -name .git 2>/dev/null |
	sed 's|/\.git$||' |
	awk -v home="$HOME" -v user="$(whoami)" '{
		path = $0
		encoded = path
		sub("^" home, "-Users-" user, encoded)
		gsub("/", "-", encoded)
		print path "\t" encoded
	}' | sort -u -t $'\t' -k2)

# Emits the time-window breakdown as CSV (Window,Cost,Project,Models),
# each window expanded into its top projects and their per-model costs.
render() {
	bunx ccusage claude daily --instances --json "${extra_args[@]}" |
		python3 -c "
import json, re, sys
from datetime import date, timedelta

marker = sys.argv[1]
mode = sys.argv[2]

root_map = []
for line in sys.argv[3].splitlines():
    if not line:
        continue
    real_path, encoded = line.split('\t')
    root_map.append((encoded, real_path.rsplit('/', 1)[-1]))
root_map.sort(key=lambda kv: -len(kv[0]))

data = json.load(sys.stdin)

matched = {
    key: entries
    for key, entries in data['projects'].items()
    if (mode == 'include') == (marker in key)
}

# Paths with no repo root on disk (removed worktrees, scratch dirs) would
# otherwise each become a row labelled by a trailing segment like
# \"workspace\", so they collapse to their first two path segments below
# \$HOME, marked with a trailing \"/…\". Matching cannot go through the
# filesystem: these paths are typically already deleted, and ccusage
# encodes \".\" to \"-\" as well, so a real path never reproduces the key.
home_prefix = sys.argv[4] + '-'

def canonical(key):
    for encoded, name in root_map:
        if key == encoded or key.startswith(encoded + '-'):
            return encoded, name
    rest = key[len(home_prefix):] if key.startswith(home_prefix) else key
    segs = [s for s in rest.split('-') if s]
    root = home_prefix + '-'.join(segs[:2])
    return root, '/'.join(segs[:2]) + '/…'

def short_model(model):
    m = model.removeprefix('claude-')
    return re.sub(r'-\d{8}\$', '', m)

# Fable is not on the ImFusion API plan; that spend lands on a personal
# subscription, so in imfusion mode it is shown parenthesised and excluded
# from the primary (billable) cost.
UNBILLED = 'fable-5'
split_billing = mode == 'include'

def model_label(model):
    return f'({model})' if split_billing and model == UNBILLED else model

def format_models(models, model_w, cost_w):
    parts = sorted(models.items(), key=lambda kv: -kv[1])
    return '\n'.join(
        f'{model_label(m):<{model_w}}  \${c:>{cost_w}.2f}' for m, c in parts
    )

def cost_cell(g):
    if not split_billing or not g['unbilled']:
        return f\"\${g['total']:.2f}\"
    return f\"\${g['total'] - g['unbilled']:.2f} (\${g['total']:.2f})\"

def cell_widths(groups):
    model_w = max(
        (len(model_label(m)) for g in groups for m in g['models']), default=0
    )
    cost_w = max((len(f'{c:.2f}') for g in groups for c in g['models'].values()), default=0)
    return model_w, cost_w

today = date.today()
this_monday = today - timedelta(days=today.weekday())
last_monday = this_monday - timedelta(days=7)
this_month_start = today.replace(day=1)

windows = [
    ('Today', today, today),
    ('Yesterday', today - timedelta(days=1), today - timedelta(days=1)),
    ('This week', this_monday, today),
    ('Last week', last_monday, this_monday - timedelta(days=1)),
    ('This month', this_month_start, today),
]
# window -> project root -> {name, total, models}
window_groups = {label: {} for label, _, _ in windows}

for key, entries in matched.items():
    root, name = canonical(key)
    for day in entries:
        d = date.fromisoformat(day['date'])
        in_windows = [label for label, start, end in windows if start <= d <= end]
        if not in_windows:
            continue
        for mb in day['modelBreakdowns']:
            model = short_model(mb['modelName'])
            for label in in_windows:
                g = window_groups[label].setdefault(
                    root, {'name': name, 'total': 0.0, 'unbilled': 0.0, 'models': {}}
                )
                g['models'][model] = g['models'].get(model, 0.0) + mb['cost']
                g['total'] += mb['cost']
                if model == UNBILLED:
                    g['unbilled'] += mb['cost']

TOP_N = 5

all_window_groups = [g for gs in window_groups.values() for g in gs.values()]
w_model_w, w_cost_w = cell_widths(all_window_groups)

print('Window,Cost,Project,Models')
for label, _, _ in windows:
    ranked = sorted(window_groups[label].values(), key=lambda g: -g['total'])
    if not ranked:
        print(f'{label},\$0.00,–,–')
        continue
    window_agg = {
        'total': sum(g['total'] for g in ranked),
        'unbilled': sum(g['unbilled'] for g in ranked),
    }
    rows, rest = ranked[:TOP_N], ranked[TOP_N:]
    rest_agg = {
        'total': sum(g['total'] for g in rest),
        'unbilled': sum(g['unbilled'] for g in rest),
    }
    name_w = max(len(g['name']) for g in rows)
    proj_cost_w = max(len(cost_cell(g)) for g in ranked)
    for i, g in enumerate(rows):
        window_cell = label if i == 0 else ''
        window_cost = cost_cell(window_agg) if i == 0 else ''
        proj = f\"{g['name']:<{name_w}}  {cost_cell(g):>{proj_cost_w}}\"
        models = format_models(g['models'], w_model_w, w_cost_w)
        print(f'{window_cell},{window_cost},\"{proj}\",\"{models}\"')
    if rest:
        label_cell = f'+{len(rest)} more'
        print(f',,\"{label_cell:<{name_w}}  {cost_cell(rest_agg):>{proj_cost_w}}\",')

grand = {'total': 0.0, 'unbilled': 0.0}
for entries in matched.values():
    for day in entries:
        for mb in day['modelBreakdowns']:
            grand['total'] += mb['cost']
            if short_model(mb['modelName']) == UNBILLED:
                grand['unbilled'] += mb['cost']
print(f'TOTAL,{cost_cell(grand)},,')

" "$marker" "$mode" "$repo_roots" "-Users-$(whoami)"
}

render_table() {
	printf '%s\n' "$1" | gum table -s , --print --border rounded --widths ""
}

render_table "$(render)"
