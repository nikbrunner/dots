{
  "system_appearance": true,
  "keymappings": {
    "toggle_window": "super+ctrl+alt+shift+KeyT"
  },
  "apps": {
    "obsidian": {
      "enabled": true,
      "config_path": "~/repos/nikbrunner/notes/.obsidian/appearance.json"
    },
    "lazygit": {
      "enabled": true,
      "config_path": "~/.config/lazygit/config.yml",
      "themes_path": "~/.config/black-atom/themes/lazygit"
    },
    "helm": {
      "enabled": true,
      "config_path": "~/.config/black-atom/helm/config.yml",
      "match_pattern": "^theme:\\s*\\S*$",
      "replace_template": "theme: {themeKey}"
    },
    "delta": {
      "enabled": true,
      "config_path": "~/.gitconfig.delta",
      "match_pattern": "features\\s*=\\s*black-atom-(dark|light)",
      "replace_template": "features = black-atom-{appearance}"
    },
    "ghostty": {
      "enabled": true,
      "config_path": "~/.config/ghostty/config",
      "match_pattern": "^theme\\s*=\\s*.+$",
      "replace_template": "theme = {themeKey}.conf"
    },
    "nvim": {
      "enabled": true,
      "config_path": "~/.config/nvim/plugin/50_specs/black_atom/nvim.lua",
      "match_pattern": "vim\\.cmd\\.colorscheme\\(\"[^\"]*\"\\)",
      "replace_template": "vim.cmd.colorscheme(\"{themeKey}\")"
    },
    "tmux": {
      "enabled": true,
      "config_path": "~/.config/tmux/tmux.conf",
      "themes_path": "~/.config/tmux/themes",
      "match_pattern": "^source-file\\s+.+/themes/.+\\.conf$",
      "replace_template": "source-file {themesPath}/{themeKey}.conf"
    },
    "zed": {
      "enabled": true,
      "config_path": "~/.config/zed/settings.json"
    }
  }
}