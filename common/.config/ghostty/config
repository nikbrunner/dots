# Generated by Spectre - Ghostty Config Generator
# https://github.com/imrajyavardhan12/spectre-ghostty-config

# Colors
theme = black-atom-jpn-murasaki-yoru.conf
bold-is-bright = true

# Window
window-padding-x = 50
window-padding-y = 25
window-vsync = true

# Advanced
custom-shader = ./shaders/boo.glsl
adjust-cell-height = 25%
adjust-cursor-thickness = 3
adjust-underline-position = 3

# Fonts
font-size = 14
font-family = Kode Mono
font-style-bold = Bold
font-thicken = false
window-inherit-working-directory = true
unfocused-split-opacity = 1
window-inherit-font-size = true
window-theme = system
window-decoration = auto

# background-opacity = 0.95
# background-blur = 65

# Cursor
cursor-style-blink = false
cursor-style = block

# Shell
shell-integration-features = no-cursor

# Macos
# macos-titlebar-style = hidden
macos-icon = paper
macos-option-as-alt = true

# Application
link-url = true
link-previews = true
# maximize = true

# Mouse
mouse-hide-while-typing = true

# Clipboard
clipboard-trim-trailing-spaces = true

# Keybinds
keybind = global:shift+ctrl+alt+space=toggle_quick_terminal
keybind = cmd+z=toggle_fullscreen

# Zoom (font size) — Moonlander sends Super+-/= 0 on media layer
keybind = super+minus=decrease_font_size:1
keybind = super+equal=increase_font_size:1
keybind = super+zero=reset_font_size

# Quick-terminal
quick-terminal-position = center
quick-terminal-size = 65%, 65%
