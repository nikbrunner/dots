# Generated by Spectre - Ghostty Config Generator
# https://github.com/imrajyavardhan12/spectre-ghostty-config

# Colors
theme = black-atom-terra-fall-day.conf
bold-is-bright = true

# Window
window-padding-x = 25
window-padding-y = 15
window-vsync = true

# Advanced
# custom-shader = ./shaders/boo.glsl
adjust-cell-height = 25%
adjust-cursor-thickness = 3
adjust-underline-position = 3

# Fonts
font-size = 14
font-family = TX-02
font-style-bold = Bold
window-inherit-working-directory = true
unfocused-split-opacity = 1
window-inherit-font-size = true
window-theme = system
window-decoration = auto

# background-opacity = 0.9
# background-blur = 3

# Cursor
cursor-style-blink = false
cursor-style = block

# Shell
shell-integration-features = no-cursor

# Macos
# macos-titlebar-style = hidden
macos-icon = paper
macos-option-as-alt = true

# Application
link-url = true
link-previews = true
# maximize = true

# Mouse
mouse-hide-while-typing = true

# Clipboard
clipboard-trim-trailing-spaces = true

# Keybinds
keybind = global:shift+ctrl+alt+space=toggle_quick_terminal
keybind = cmd+z=toggle_fullscreen

# Quick-terminal
quick-terminal-position = center
quick-terminal-size = 65%, 65%
