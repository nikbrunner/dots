{
  "my snippet": {
    "prefix": "log",
    "body": ["console.log(\"$1\")"],
    "description": "Expand `log` to `console.log()`"
  },
  "Date": {
    "prefix": "today",
    "body": "${CURRENT_YEAR}.${CURRENT_MONTH}.${CURRENT_DATE} - ${CURRENT_DAY_NAME_SHORT}",
    "description": "Date: today"
  },
  "Date with wikilink": {
    "prefix": "today-link",
    "body": "[[${CURRENT_YEAR}.${CURRENT_MONTH}.${CURRENT_DATE} - ${CURRENT_DAY_NAME_SHORT}]]",
    "description": "Date: today (wikilink)"
  },
  "Date with header": {
    "prefix": "today-header",
    "body": "## ${CURRENT_YEAR}.${CURRENT_MONTH}.${CURRENT_DATE} - ${CURRENT_DAY_NAME_SHORT}",
    "description": "Date: today (h2 header)"
  },
  "Month": {
    "prefix": "month",
    "body": "${CURRENT_YEAR}.${CURRENT_MONTH} - ${CURRENT_MONTH_NAME}",
    "description": "Month: current"
  },
  "Month with wikilink": {
    "prefix": "month-link",
    "body": "[[${CURRENT_YEAR}.${CURRENT_MONTH} - ${CURRENT_MONTH_NAME}]]",
    "description": "Month: current (wikilink)"
  },
  "Time": {
    "prefix": "time",
    "body": "${CURRENT_HOUR}:${CURRENT_MINUTE}",
    "description": "Time (HH:MM)"
  }
}
