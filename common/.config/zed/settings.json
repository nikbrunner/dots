{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "document_symbols": "on",
  "session": {
    "trust_all_worktrees": false,
  },
  "buffer_font_family": "TX-02 ExtraCondensed",
  "which_key": {
    "delay_ms": 250,
    "enabled": true,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "agent_buffer_font_size": 20.0,
  "agent_ui_font_size": 20.0,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-6-latest",
      "enable_thinking": false,
    },
    "use_modifier_to_send": true,
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5",
    },
  },
  "hide_mouse": "on_typing_and_movement",
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
    "enabled_in_text_threads": false,
  },
  "ssh_connections": [
    {
      "host": "BC_OFFICE_LAN",
      "projects": [],
    },
  ],
  "cursor_blink": false,
  "theme": {
    "mode": "light",
    "light": "Black Atom — MNML ∷ 47 Light",
    "dark": "Black Atom — TERRA ∷ Fall Night"
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 16.0,
  "buffer_line_height": "comfortable",
  "buffer_font_size": 16.0,
  "buffer_font_weight": 400,
  "show_completions_on_input": true,
  "tabs": {
    "show_diagnostics": "all",
    "git_status": true,
    "file_icons": true,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "git": {
    "git_gutter": "tracked_files",
  },
  "indent_guides": {
    "enabled": false,
  },
  "git_panel": {
    "dock": "left",
    "status_style": "icon",
    "sort_by_path": true,
  },
  "project_panel": {
    "dock": "left",
    "git_status": true,
    "indent_guides": {
      "show": "never",
    },
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
    },
  },
  "format_on_save": "on",
  "terminal": {
    "line_height": "standard",
    "working_directory": "current_project_directory",
    "font_family": "TX-02 ExtraCondensed",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "relative",
          },
        },
      },
    },
    "eslint": {
      "settings": {
        "eslint": {
          "enable": true,
        },
      },
    },
    "biome": {
      "settings": {
        "config_path": "./biome.json",
        "require_config_file": true,
      },
    },
  },
  "ui_font_family": "TX-02 ExtraCondensed",
}
