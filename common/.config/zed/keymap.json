[
  // ============================================================
  // Global (all contexts)
  // ============================================================
  {
    "bindings": {
      "ctrl-s": "workspace::SaveAll",
      "ctrl-q": "pane::CloseActiveItem",

      "alt-[": "workspace::ToggleLeftDock",
      "alt-]": "workspace::ToggleRightDock",

      // --- App Scope (AWDCS: A) ---
      ", a a": "command_palette::Toggle",
      ", a g": "git_panel::ToggleFocus",
      ", a t": "theme_selector::Toggle",
      ", a ,": "zed::OpenSettings",
      ", a k": "zed::OpenKeymap",
      ", a w": "projects::OpenRecent",
      ", a i a": "editor::ToggleEditPrediction",
      ", a f": "workspace::ToggleZenMode",
      ", a z": "workspace::ToggleCenteredLayout",

      // --- Pane Navigation ---
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },

  // ============================================================
  // Workspace context (AWDCS: W)
  // ============================================================
  {
    "context": "Workspace",
    "bindings": {
      ", ,": "file_finder::Toggle",
      ", w d": "file_finder::Toggle",
      ", w r": "tab_switcher::Toggle",
      ", w s": "project_symbols::Toggle",
      ", w f": "pane::DeploySearch",
      ", w t": "pane::DeploySearch",
      ", w e": "project_panel::ToggleFocus",
      ", w p": "diagnostics::Deploy",
      ", w m": "git::OpenModifiedFiles",
      ", w g b": "branches::OpenRecent"
    }
  },

  // ============================================================
  // Editor — full mode (expand excerpts)
  // ============================================================
  {
    "context": "Editor && mode == full",
    "bindings": {
      "shift-enter": ["editor::ExpandExcerpts", { "lines": 5 }]
    }
  },

  // ============================================================
  // Editor — Vim Normal (AWDCS: D, C, S + Navigation)
  // ============================================================
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // --- Navigation ---
      "H": "pane::ActivatePreviousItem",
      "L": "pane::ActivateNextItem",
      "space": ["workspace::SendKeystrokes", "c i w"],

      // --- Document Scope (AWDCS: D) ---
      ", d f": "buffer_search::Deploy",
      ", d s": "outline::Toggle",
      ", d l": "pane::AlternateFile",
      ", d p": "editor::GoToDiagnostic",
      ", d y p": "workspace::CopyRelativePath",
      ", d y a": "workspace::CopyPath",
      ", d g r": "git::RestoreFile",
      ", d g s": "git::StageFile",

      // --- Change Scope (AWDCS: C) ---
      ", c r": "git::Restore",
      ", c s": "git::StageAndNext",
      ", c d": "editor::ToggleSelectedDiffHunks",
      ", c g": "editor::ToggleSelectedDiffHunks",
      "] c": "editor::GoToNextChange",
      "[ c": "editor::GoToPreviousChange",

      // --- Symbol Scope (AWDCS: S) ---
      ", s d": "editor::GoToDefinition",
      ", s r": "editor::FindAllReferences",
      ", s i": "editor::Hover",
      ", s n": "editor::Rename",
      ", s a": "editor::ToggleCodeActions",
      ", s t": "editor::GoToTypeDefinition",
      ", s shift-i": "editor::GoToImplementation",
      ", s g b": "editor::BlameHover",

      // --- Custom ---
      "y c": ["workspace::SendKeystrokes", "y y g c c p"]
    }
  },

  // ============================================================
  // Editor — Vim Visual
  // ============================================================
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      "g a": "agent::QuoteSelection",
      "v": "editor::SelectLargerSyntaxNode",
      "V": "editor::SelectSmallerSyntaxNode",
      "A": "editor::SelectAll",
      "K": "editor::MoveLineUp",
      "J": "editor::MoveLineDown",
      ", c c g": "editor::CopyPermalinkToLine"
    }
  },

  // ============================================================
  // Editor — Vim Insert
  // ============================================================
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {}
  },

  // ============================================================
  // Project Panel
  // ============================================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "escape": "project_panel::ToggleFocus",
      ", e e": "workspace::ToggleLeftDock",
      "h": "project_panel::CollapseSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "project_panel::ExpandSelectedEntry",
      "enter": "project_panel::OpenPermanent",
      "r": "project_panel::Rename",
      "z c": "project_panel::CollapseSelectedEntry",
      "z o": "project_panel::ExpandSelectedEntry",
      "z m": "project_panel::CollapseSelectedEntry",
      "z M": "project_panel::CollapseAllEntries",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "d": "project_panel::Trash",
      "a": "project_panel::NewFile",
      "shift-a": "project_panel::NewDirectory",
      "shift-y": "workspace::CopyRelativePath",
      "g y": "workspace::CopyPath"
    }
  },

  // ============================================================
  // Terminal
  // ============================================================
  {
    "context": "Terminal",
    "bindings": {
      "alt-h": "pane::ActivatePreviousItem",
      "alt-l": "pane::ActivateNextItem"
    }
  }
]
