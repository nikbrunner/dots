[
  // ============================================================
  // Global (all contexts)
  // ============================================================
  {
    "bindings": {
      "ctrl-s": "workspace::SaveAll",
      "ctrl-q": "pane::CloseActiveItem",

      "alt-[": "workspace::ToggleLeftDock",
      "alt-]": "workspace::ToggleRightDock",

      // NOTE: `,` is nulled in the vim normal/visual blocks below (scoped),
      // not here — a global null loses to the default's context-scoped
      // `vim::RepeatFindReversed` binding.

      // --- App Scope (AWDCS: A) ---
      ", a a": "command_palette::Toggle",
      ", a g": "git_panel::ToggleFocus",
      ", a t": "theme_selector::Toggle",
      ", a ,": "zed::OpenSettings",
      ", a k": "zed::OpenKeymap",
      ", a w": "projects::OpenRecent",
      ", a i a": "editor::ToggleEditPrediction",
      ", a z": "workspace::ToggleCenteredLayout",

      // --- Pane Navigation ---
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },

  // ============================================================
  // Workspace context (AWDCS: W)
  // ============================================================
  {
    "context": "Workspace",
    "bindings": {
      // , , and , w d both → file_finder::Toggle. Kept both: , , for fast access, , w d for AWDCS consistency.
      ", ,": "file_finder::Toggle",
      ", w d": "file_finder::Toggle",
      ", w r": "tab_switcher::Toggle",
      ", w s": "project_symbols::Toggle",
      ", w t": "pane::DeploySearch",
      ", w e": "project_panel::ToggleFocus",
      ", w p": "diagnostics::Deploy",
      ", w m": "git::OpenModifiedFiles",
      ", w g b": "git::Branch",
    },
  },

  // ============================================================
  // Editor — full mode (expand excerpts)
  // ============================================================
  {
    "context": "Editor && mode == full",
    "bindings": {
      "shift-enter": ["editor::ExpandExcerpts", { "lines": 5 }],
    },
  },

  // ============================================================
  // Editor — Vim Normal (AWDCS: D, C, S + Navigation)
  // ============================================================
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // Kill the default `,` (vim::RepeatFindReversed) so it stops racing
      // the leader sequences. Must be scoped here to win precedence.
      ",": null,

      // Neutralize `s` so two-key `s<key>` Symbol bindings resolve. The default
      // `s` = vim::Substitute fires instantly (operator, not a keymap binding),
      // so `null` does NOT suppress it. `vim::PushSneak` is the documented
      // override: it replaces substitute with a wait-for-input state.
      // `sd`/`sr`/etc. resolve as more-specific bindings before sneak's jump.
      // Use `cl` for substitute (s no longer substitutes).
      "s": "vim::PushSneak",

      // Deliberate: H/L = pane prev/next (matches nvim tab nav). Loses vim WindowTop/WindowBottom.
      // --- Navigation ---
      "H": "pane::ActivatePreviousItem",
      "L": "pane::ActivateNextItem",
      "-": "pane::RevealInProjectPanel",

      // --- Document Scope (AWDCS: D) ---
      ", d f": "buffer_search::Deploy",
      ", d s": "outline::Toggle",
      ", d l": "pane::AlternateFile",
      ", d p": "diagnostics::DeployCurrentFile",
      ", d y p": "workspace::CopyRelativePath",
      ", d y a": "workspace::CopyPath",
      ", d y n": "editor::CopyFileName",
      ", d g r": "git::RestoreFile",
      ", d g s": "git::StageFile",

      // --- Change Scope (AWDCS: C) ---
      ", c r": "git::Restore",
      ", c s": "git::StageAndNext",
      ", c d": "editor::ToggleSelectedDiffHunks",
      "] c": "editor::GoToHunk",
      "[ c": "editor::GoToPreviousHunk",

      // --- Symbol Scope (AWDCS: S) — leaderless; `s` neutralized above ---
      "sd": "editor::GoToDefinition",
      "sV": "editor::GoToDefinitionSplit",
      "sr": "editor::FindAllReferences",
      "si": "editor::GoToImplementation",
      "sh": "editor::Hover",
      "sn": "editor::Rename",
      "sa": "editor::ToggleCodeActions",
      "st": "editor::GoToTypeDefinition",
      "sD": "editor::GoToDeclaration",
      "sgb": "editor::BlameHover",

      // --- Custom ---
      // "y c": ["workspace::SendKeystrokes", "y y g c c p"],
    },
  },

  // ============================================================
  // Editor — Vim Visual
  // ============================================================
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      ",": null,
      // Deliberate: A = SelectAll, g a = agent::AddSelectionToThread. Loses default A=InsertAfter, g a=SelectAllMatches.
      "g a": "agent::AddSelectionToThread",
      // Deliberate: v/V = tree-sitter select larger/smaller (mini.ai/grug style). Loses visual-mode toggle.
      "v": "editor::SelectLargerSyntaxNode",
      "V": "editor::SelectSmallerSyntaxNode",
      "A": "editor::SelectAll",
      "K": "editor::MoveLineUp",
      "J": "editor::MoveLineDown",
      ", c c g": "editor::CopyPermalinkToLine",
    },
  },

  // ============================================================
  // Project Panel
  // ============================================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "escape": "project_panel::ToggleFocus",
      "q": "project_panel::ToggleFocus",
      ", e e": "workspace::ToggleLeftDock",
      "h": "project_panel::CollapseSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "project_panel::ExpandSelectedEntry",
      "enter": "project_panel::OpenPermanent",
      "r": "project_panel::Rename",
      "z c": "project_panel::CollapseSelectedEntry",
      "z o": "project_panel::ExpandSelectedEntry",
      "z m": "project_panel::CollapseSelectedEntry",
      "z M": "project_panel::CollapseAllEntries",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "d": "project_panel::Trash",
      "a": "project_panel::NewFile",
      "shift-a": "project_panel::NewDirectory",
      "shift-y": "workspace::CopyRelativePath",
      "g y": "workspace::CopyPath",
    },
  },

  // ============================================================
  // Git Panel
  // ============================================================
  {
    "context": "GitPanel && !edit_prediction",
    "bindings": {
      "q": "git_panel::ToggleFocus",
    },
  },

  // ============================================================
  // Terminal
  // ============================================================
  {
    "context": "Terminal",
    "bindings": {
      "alt-h": "pane::ActivatePreviousItem",
      "alt-l": "pane::ActivateNextItem",
    },
  },
]
