{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "typeRoots": [
      "/opt/homebrew/lib/node_modules/@mariozechner/pi-coding-agent/node_modules/@types"
    ],
    "paths": {
      "@mariozechner/pi-coding-agent": [
        "/opt/homebrew/lib/node_modules/@mariozechner/pi-coding-agent/dist/index.d.ts"
      ],
      "@sinclair/typebox": [
        "/opt/homebrew/lib/node_modules/@sinclair/typebox/index.d.ts"
      ]
    }
  },
  "include": ["./*.ts"]
}
