{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "0",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(claude mcp list:*)",
      "Bash(claude mcp tools:*)",
      "Bash(curl:*)",
      "Bash(cut:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(grep:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npm run check:*)",
      "Bash(npm run check:lint:*)",
      "Bash(npm run check:types:*)",
      "Bash(npm run db:push:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run format:*)",
      "Bash(npm run storybook:start:*)",
      "Bash(npm run test:*)",
      "Bash(npm run test:compile:*)",
      "Bash(npm uninstall:*)",
      "Bash(npx eslint:*)",
      "Bash(npx jest:*)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npx shadcn@latest init --yes)",
      "Bash(npx supabase --help:*)",
      "Bash(npx supabase db --help:*)",
      "Bash(npx supabase link --help:*)",
      "Bash(pkill:*)",
      "Bash(timeout 10 npm run dev:*)",
      "Bash(timeout 5 npm run dev:*)",
      "Bash(timeout 8 npm run dev:*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "mcp__Ref__ref_read_url",
      "mcp__Ref__ref_search_documentation",
      "mcp__chrome-devtools__*",
      "mcp__exa__*",
      "mcp__linear__*",
      "mcp__atlassian-rovo-mcp__*",
      "mcp__supabase__*"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/helm-hook Notification"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"permissionDecision\": \"allow\"}}'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/helm-hook PreToolUse"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce/semantic-commits.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce/warn-any-type.sh"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell|Grep|Glob|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "repowise-augment",
            "timeout": 10,
            "statusMessage": "Checking codebase context..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/helm-hook SessionStart"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/helm-hook Stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/helm-hook SessionEnd"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce/skills-check.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce/current-datetime.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/claude-statusline"
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "impeccable@impeccable": true,
    "plannotator@plannotator": true,
    "figma@claude-plugins-official": true,
    "repowise@repowise": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "readwise-skills": {
      "source": {
        "source": "github",
        "repo": "readwiseio/readwise-skills"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "repowise": {
      "source": {
        "source": "github",
        "repo": "repowise-dev/repowise"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoDreamEnabled": true,
  "theme": "light-ansi",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754313915132
  },
  "mcpServers": {
    "repowise": {
      "command": "/Users/brunner/.local/pipx/venvs/repowise/bin/repowise",
      "args": [
        "mcp",
        "/Users/brunner/repos/imfusion/websdk/web-ui/.workspaces/websdk-152-storybook-harness",
        "--transport",
        "stdio"
      ],
      "description": "repowise: codebase intelligence — docs, graph, git signals, dead code, decisions"
    }
  }
}
